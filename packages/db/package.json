{
  "name": "@guardora/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "generate": "prisma generate",
    "guard:db": "dotenv -e ../../.env.local -e ../../.env -- tsx scripts/assert-local-db.cli.ts",
    "assert-local-db:test": "tsx scripts/assert-local-db.test.ts",
    "migrate": "dotenv -e ../../.env.local -e ../../.env -- sh -c 'tsx scripts/assert-local-db.cli.ts && prisma migrate dev'",
    "migrate:deploy": "dotenv -e ../../.env.local -e ../../.env -- sh -c 'tsx scripts/assert-local-db.cli.ts && prisma migrate deploy'",
    "push": "dotenv -e ../../.env.local -e ../../.env -- sh -c 'tsx scripts/assert-local-db.cli.ts && prisma db push'",
    "seed": "dotenv -e ../../.env.local -e ../../.env -- sh -c 'tsx scripts/assert-local-db.cli.ts && tsx prisma/seed.ts'",
    "set-app-role-password": "dotenv -e ../../.env -- tsx scripts/set-app-role-password.ts",
    "db-check": "dotenv -e ../../.env -- tsx scripts/db-doctor.ts",
    "studio": "dotenv -e ../../.env -- prisma studio",
    "reconnect-check": "dotenv -e ../../.env -- tsx scripts/reconnect-regression.ts",
    "reclassify-demo": "dotenv -e ../../.env -- tsx scripts/reclassify-demo.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@guardora/ai": "workspace:*",
    "@guardora/core": "workspace:*",
    "@node-rs/argon2": "^2.0.2",
    "@prisma/client": "^6.2.0"
  },
  "devDependencies": {
    "dotenv-cli": "^7.4.4",
    "prisma": "^6.2.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0"
  }
}
