// =============================================================================
// Guardora.ai — Prisma schema
//
// Multi-tenant, multi-brand, multi-platform reputation model.
// Mirrors @guardora/core domain types. Enums are kept in sync with core.
// No client passwords are stored. Connector tokens come from official OAuth only.
// =============================================================================

generator client {
  provider      = "prisma-client-js"
  // "native" keeps local macOS/Linux dev working; "rhel-openssl-3.0.x" is the Vercel
  // serverless runtime target — without it the Linux Query Engine is never generated and
  // Prisma fails to initialize in production (libquery_engine-rhel-openssl-3.0.x.so.node).
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Enums -------------------------------------------------------------------

enum Platform {
  facebook_page
  instagram_business
  youtube
  linkedin_company
  tiktok
  google_business
}

enum Role {
  owner
  admin
  analyst
  reviewer
  viewer
}

// V1.45A — GLOBAL platform-administration role, INDEPENDENT of tenant Role. Governs cross-tenant
// platform surfaces (e.g. the global prospect/leads admin). Default `none` — a tenant owner/admin
// has ZERO platform privilege. Never assigned by tenant UI, migration, or startup.
enum PlatformRole {
  none
  staff
  admin
}

// V1.45C1 — tenant deletion lifecycle. `active` is the only state in which ordinary tenant
// activity (sessions, sync, webhook ingest, membership/provider changes) may proceed. Once a
// tenant transitions to `deleting`, every activity path fails closed (see assertTenantActive /
// the session guard) and only the deletion orchestrator + narrow system cleanup may touch it.
// The final tenant row is PHYSICALLY deleted at the end — there is no `deleted` state.
enum TenantDeletionState {
  active
  deleting
}

// V1.45C1 — status of a durable, PRIVACY-SAFE global deletion receipt (see TenantDeletionReceipt).
enum TenantDeletionStatus {
  requested
  completed
  failed
}

enum BrandStatus {
  active
  paused
  archived
}

enum BrandTone {
  professional
  friendly
  formal
  casual
  empathetic
}

enum ConnectorStatus {
  pending
  active
  mock_connected
  expired
  disconnected
  error
}

enum ConnectorMode {
  placeholder
  oauth_ready
  read_only
  action_disabled
}

enum ConnectorHealth {
  unknown
  healthy
  degraded
  error
}

enum SyncRunStatus {
  running
  completed
  failed
  // V1.37.4 — truthful sync outcomes.
  partial_success
  skipped_locked
  disconnected
  permission_missing
  rate_limited
  api_unavailable
}

enum ContentKind {
  comment
  reply
  review
  mention
  direct_message
}

enum ReputationStatus {
  new
  classified
  needs_approval
  actioned
  escalated
  ignored
  resolved
}

enum Priority {
  low
  normal
  high
  urgent
}

// V1.42 — internal inbox workflow status (Tamanor-side triage; NOT provider moderation state).
// `resolved` here NEVER implies a provider comment was hidden/deleted/replied.
enum InboxWorkflowStatus {
  new
  in_review
  action_required
  resolved
}

// V1.44B — truthful per-item AI processing state. NEVER implies fabricated sentiment/risk: a
// limit/disabled/failed status means the advanced tier did not run, not that analysis was invented.
enum InboxProcessingStatus {
  pending
  processed_rules
  processed_local
  processed_paid
  cached
  basic_limit_reached
  premium_limit_reached
  paid_ai_disabled
  failed
}

enum RuleCategory {
  blocked_words
  competitor_mentions
  crisis_keywords
  custom_phrases
}

enum RiskLevel {
  none
  low
  medium
  high
  critical
}

enum Sentiment {
  negative
  neutral
  positive
}

enum ModerationAction {
  none
  reply
  hide
  delete
  ignore
  mark_resolved
  escalate
}

enum ActorKind {
  ai
  human
  rule
  system
}

enum DecisionStatus {
  proposed
  approved
  rejected
  executed
  failed
  cancelled
}

// --- Identity & tenancy ------------------------------------------------------

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  name         String?
  // V1.50A — self-service credential auth. Argon2id PHC string (never plaintext).
  // Nullable: dev-seed/E2E/future-OAuth users may have no local password.
  passwordHash String?
  // V1.50C — email verification + password lifecycle.
  //   emailVerifiedAt: null until the email is verified (email/password) or set at creation
  //     for an OAuth provider-verified email. Gates verification-required product access.
  //   passwordChangedAt: set on every password reset; a session created before this is stale
  //     (defense-in-depth backstop in session hydrate, on top of explicit session revocation).
  emailVerifiedAt   DateTime?
  passwordChangedAt DateTime?
  locale       String       @default("en")
  // V1.45A — global platform-admin role (default least-privilege; independent of tenant Role).
  platformRole PlatformRole @default(none)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  memberships             Membership[]
  oauthAccounts           OAuthAccount[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  proposed           ModerationDecision[] @relation("DecisionProposer")
  reviewed           ModerationDecision[] @relation("DecisionReviewer")
  auditLogs          AuditLog[]
  sessions           UserSession[]
  // V1.42 — inbox assignment + note authorship (both SetNull on user delete).
  assignedInboxItems ReputationItem[]     @relation("InboxAssignee")
  inboxNotes         InboxNote[]          @relation("InboxNoteAuthor")

  @@map("users")
}

// V1.50B — external identity link for USER authentication (Google / Facebook Login).
// This is ONE user with potentially MANY login providers. It is entirely separate from
// the Meta Page/Business connector (ConnectedAccount / MetaOnboardingSession): it stores
// only the provider's opaque account id for sign-in, never a Page/business access token,
// and is never used to act on a platform. No provider access/refresh token is persisted —
// once the callback has read the account id + email, the token is discarded.
model OAuthAccount {
  id                String   @id @default(cuid())
  userId            String
  provider          String   // "google" | "facebook" (USER login providers only)
  providerAccountId String   // the provider's stable subject/user id (e.g. Google `sub`)
  createdAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // One external identity maps to at most one Tamanor user; a user has at most one link per provider.
  @@unique([provider, providerAccountId])
  @@unique([userId, provider])
  @@index([userId])
  @@map("oauth_accounts")
}

// V1.50C — one-time email verification token. Same fail-closed design as the session:
// a random raw token is emailed to the user; only its SHA-256 hash is stored here. A raw
// token NEVER touches the DB. One-time via an atomic guarded consume (consumedAt). Separate
// from UserSession — session tokens are never reused for email flows.
model EmailVerificationToken {
  id         String    @id @default(cuid())
  tokenHash  String    @unique
  userId     String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("email_verification_tokens")
}

// V1.50C — one-time password-reset token. Identical fail-closed, hash-at-rest design.
// A successful reset consumes the token, sets User.passwordChangedAt, and revokes every
// existing session for the user.
model PasswordResetToken {
  id         String    @id @default(cuid())
  tokenHash  String    @unique
  userId     String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

// V1.37.1 — opaque, DB-backed session. The cookie holds a random token; only
// its SHA-256 hash is stored here. A raw token is NEVER persisted. Sessions are
// fail-closed: expired/revoked/membership-missing → rejected.
model UserSession {
  id             String    @id @default(cuid())
  tokenHash      String    @unique
  userId         String
  activeTenantId String
  createdAt      DateTime  @default(now())
  expiresAt      DateTime
  lastSeenAt     DateTime  @default(now())
  revokedAt      DateTime?
  rotatedFromId  String?

  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeTenant Tenant @relation(fields: [activeTenantId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([activeTenantId])
  @@index([expiresAt])
  @@map("user_sessions")
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  plan      String   @default("free")
  // V1.50A — self-service Free Trial. On registration: plan="free_trial" with a
  // 14-day window. Billing is out of scope (V1.50B+); these are informational only.
  trialStartsAt DateTime?
  trialEndsAt   DateTime?
  // Optional company country captured at registration (no downstream logic yet).
  country       String?
  // V1.50B — onboarding state. NULL = onboarding pending (new workspace); set when the
  // owner finishes or skips the onboarding wizard, so it is shown once, not on every login.
  onboardingCompletedAt DateTime?
  // V1.50D — billing state (derived from Stripe via the webhook; the Subscription row holds the
  // detail). `billingStatus` is the truthful Stripe-aligned status; `accessState` is the central
  // application access decision. Defaults keep a trial-only tenant on full access.
  billingStatus String @default("no_subscription")
  accessState   String @default("full_access")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // V1.45C1 — deletion lifecycle. Default `active`; NON-NULL. A tenant is marked `deleting`
  // atomically at the start of the deletion lifecycle (see requestTenantDeletion). The
  // operation id is server-generated (never client-chosen) and unique so two concurrent
  // requests converge on one operation and a stale op-id can never affect another lifecycle.
  deletionState       TenantDeletionState @default(active)
  deletionRequestedAt DateTime?
  deletionOperationId String?             @unique

  memberships       Membership[]
  brands            Brand[]
  connectedAccounts ConnectedAccount[]
  contentItems      ContentItem[]
  reputationItems   ReputationItem[]
  decisions         ModerationDecision[]
  brandRules        BrandRule[]
  auditLogs         AuditLog[]
  reportSnapshots   ReportSnapshot[]
  metaOnboarding    MetaOnboardingSession[]
  inboxLabels       InboxLabel[]
  sessions          UserSession[]
  usagePeriods      UsagePeriod[]
  usageEvents       UsageEvent[]
  aiResultCache     AiResultCache[]
  subscription      Subscription?

  // V1.45C1 — tenant-scoped tables that previously carried only a `tenantId` string (RLS-isolated
  // but NOT FK-linked). These now cascade on tenant deletion so the DB cascade graph is COMPLETE
  // and provable (no orphaned tenant-scoped rows survive a tenant delete).
  brandRiskFeedback        BrandRiskFeedback[]
  brandRiskMemoryRules     BrandRiskMemoryRule[]
  controlPolicies          ControlPolicy[]
  actionQueueItems         ActionQueueItem[]
  incidents                Incident[]
  brandAutoProtectPolicies BrandAutoProtectPolicy[]
  autoProtectDecisions     AutoProtectDecision[]
  platformActionExecutions PlatformActionExecution[]
  providerCalls            ProviderCall[]
  // V1.45C1 — durable tenant link for matched raw webhook events (explicit purge on deletion).
  webhookEvents            WebhookEvent[]

  @@map("tenants")
}

// V1.50D — the tenant's subscription. Stores ONLY safe Stripe identifiers + billing state; never
// card numbers, CVC, payment methods, or raw payloads. One subscription per tenant (the active
// billing relationship). Written ONLY by the Stripe webhook processor from trusted Stripe data.
model Subscription {
  id                   String    @id @default(cuid())
  tenantId             String    @unique
  stripeCustomerId     String    @unique
  stripeSubscriptionId String?   @unique
  stripePriceId        String?
  plan                 String    // billing plan id (starter|growth|agency|enterprise|free_trial)
  billingInterval      String?   // "monthly" | "yearly"
  status               String    // Stripe-aligned status
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)
  canceledAt           DateTime?
  trialEndsAt          DateTime?
  latestInvoiceStatus  String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([stripeCustomerId])
  @@map("subscriptions")
}

// V1.50D — Stripe webhook idempotency + bounded audit. The Stripe event ID is UNIQUE, so a retried
// or replayed delivery is processed at most once. Stores a SAFE result classification only — never
// the full payment payload, card data, email, or Stripe response body. Old rows are purged on a
// bounded retention schedule (like webhook_events).
model StripeWebhookEvent {
  id          String    @id @default(cuid())
  stripeEventId String  @unique
  eventType   String
  result      String    // "processed" | "ignored" | "failed"
  processedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([createdAt])
  @@map("stripe_webhook_events")
}

model Membership {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String
  role      Role     @default(viewer)
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@index([tenantId])
  @@map("memberships")
}

// --- Brands & connectors -----------------------------------------------------

model Brand {
  id            String      @id @default(cuid())
  tenantId      String
  name          String
  displayName   String?
  defaultLocale String      @default("en")
  timezone      String      @default("UTC")
  defaultTone   BrandTone   @default(professional)
  status        BrandStatus @default(active)
  // V1.27 Production Safe Mode — per-brand kill switch. When true, NO live action.
  killSwitch    Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  tenant            Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  connectedAccounts ConnectedAccount[]
  contentItems      ContentItem[]
  reputationItems   ReputationItem[]
  decisions         ModerationDecision[]
  brandRules        BrandRule[]
  reportSnapshots   ReportSnapshot[]
  liveSafety        BrandLiveSafetySettings?

  @@index([tenantId])
  @@map("brands")
}

/// V1.27 Production Safe Mode — per-brand live-action safety envelope. Fail-closed
/// defaults: live off, autonomous off, low limits, high confidence, crisis lock on.
model BrandLiveSafetySettings {
  id                                 String   @id @default(cuid())
  tenantId                           String
  brandId                            String   @unique
  liveModeEnabled                    Boolean  @default(false)
  autonomousHideEnabled              Boolean  @default(false)
  approvalRequiredAboveDailyLimit    Boolean  @default(true)
  dailyAutoHideLimit                 Int      @default(10)
  hourlyAutoHideLimit                Int      @default(3)
  perCategoryDailyLimit              Int      @default(5)
  maxConsecutiveWithoutReview        Int      @default(5)
  minConfidenceForAutoHide           Float    @default(0.85)
  requireDryRunBeforeFirstLive       Boolean  @default(true)
  requireHumanApprovalForNewCategory Boolean  @default(true)
  rollbackRequiredBeforeAutonomy     Boolean  @default(true)
  crisisLockEnabled                  Boolean  @default(true)
  // Categories the brand has explicitly approved for autonomous auto-hide.
  approvedAutoHideCategories         String[]
  createdAt                          DateTime @default(now())
  updatedAt                          DateTime @updatedAt

  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("brand_live_safety_settings")
}

model ConnectedAccount {
  id                 String          @id @default(cuid())
  tenantId           String
  brandId            String
  platform           Platform
  status             ConnectorStatus @default(pending)
  mode               ConnectorMode   @default(placeholder)
  health             ConnectorHealth @default(unknown)
  externalId         String
  externalName       String?
  // Meta specifics
  pageId             String?
  igBusinessId       String?
  scopes             String[]
  // Permissions the user actually granted (may differ from requested scopes).
  grantedPermissions String[]
  // V1.27 Production Safe Mode — per-account kill switch. When true, NO live action.
  killSwitch         Boolean         @default(false)

  // V1.27C Persistent Connection Manager — token/connection health, separate from
  // sync health. A hide never runs on an unverified token.
  connectionStatus           String    @default("connected") // connected|needs_reconnect|invalid_token|missing_permission|disabled_by_user|disconnected
  tokenHealth                String    @default("unknown") // unknown|ok|expiring_soon|expired|invalid|revoked
  lastTokenCheckAt           DateTime?
  lastTokenCheckResult       String?
  lastSuccessfulGraphCheckAt DateTime?
  lastReconnectAt            DateTime?
  lastPermissionCheckAt      DateTime?
  requiresReconnectReason    String?

  // ---------------------------------------------------------------------------
  // TOKENS — obtained via official OAuth ONLY (never passwords/scraping).
  // DEV NOTE: stored as plaintext in development for simplicity.
  // PRODUCTION REQUIREMENT: these columns MUST be encrypted at rest (KMS/envelope
  // encryption). Tokens are never returned to the UI and never logged.
  // See docs/SECURITY.md.
  // ---------------------------------------------------------------------------
  accessToken    String?
  longLivedToken String?
  refreshToken   String?
  tokenType      String?
  tokenExpiresAt DateTime?

  lastSyncedAt         DateTime?
  lastSuccessfulSyncAt DateTime?
  // Last external content cursor/timestamp seen (for incremental reads).
  lastCursor           String?
  lastError            String?
  lastErrorAt          DateTime?
  // Read-only sync retry/backoff state (no aggressive retry loops).
  syncAttempts         Int       @default(0)
  nextRetryAt          DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // V1.38 — canonical Meta asset linkage. An Instagram Business account references
  // its parent Facebook Page account. The FK (ON DELETE SET NULL) + a cross-tenant
  // trigger live in raw SQL (a composite SetNull would null the RLS tenantId) — same
  // pattern as the V1.37.5B history group. IG survives a Page removal with a null link.
  parentAccountId String?

  // V1.38.1 — last truthful Instagram content permission/availability state. One of
  // healthy|permission_missing|app_review_pending|business_verification_required|
  // token_expired|instagram_not_linked|professional_account_required|
  // account_not_discoverable|api_unavailable|rate_limited. Set ONLY from a real signal.
  contentPermissionState String?

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  brand         Brand          @relation(fields: [brandId], references: [id], onDelete: Cascade)
  contentItems  ContentItem[]
  syncRuns      SyncRun[]
  syncLeases    SyncLease[]
  // V1.45C1 — informational back-link from matched raw webhook events (ON DELETE SetNull).
  webhookEvents WebhookEvent[]

  @@unique([brandId, platform, externalId])
  @@index([tenantId])
  @@index([brandId])
  @@index([parentAccountId])
  @@map("connected_accounts")
}

model SyncRun {
  id                 String        @id @default(cuid())
  tenantId           String
  brandId            String
  connectedAccountId String
  status             SyncRunStatus @default(running)
  // Whether this run used the MOCK fallback (placeholder mode).
  mock               Boolean       @default(false)
  fetched            Int           @default(0)
  created            Int           @default(0)
  // V1.37.4 — resynced existing items whose provider content changed.
  updated            Int           @default(0)
  deduped            Int           @default(0)
  errors             Int           @default(0)
  error              String?
  durationMs         Int?
  // External content cursor/timestamp reached by this run, if any.
  cursor             String?
  startedAt          DateTime      @default(now())
  finishedAt         DateTime?

  connectedAccount ConnectedAccount @relation(fields: [connectedAccountId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([connectedAccountId, startedAt])
  @@map("sync_runs")
}

/**
 * V1.37.4 — account-level sync lease. At most ONE active lease per connected
 * account (unique on connectedAccountId), so a manual + scheduled sync of the same
 * account cannot run concurrently. The lease is DB-backed state (NOT an open DB
 * transaction): it has a TTL so a crashed holder never blocks the account forever —
 * an expired lease can be atomically taken over. Tenant-scoped under RLS.
 */
model SyncLease {
  id                 String   @id @default(cuid())
  tenantId           String
  connectedAccountId String   @unique
  holderId           String
  acquiredAt         DateTime @default(now())
  expiresAt          DateTime
  heartbeatAt        DateTime @default(now())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  connectedAccount ConnectedAccount @relation(fields: [connectedAccountId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([expiresAt])
  @@map("sync_leases")
}

/// Short-lived OAuth onboarding state between the Meta callback and Page
/// selection. Holds discovery results INCLUDING per-page access tokens.
///
/// SECURITY: `userAccessToken` and the tokens embedded in `pages` are SECRETS —
/// server-only, never returned to the UI, never logged. DEV stores plaintext;
/// PRODUCTION must encrypt at rest (see docs/SECURITY.md). Rows expire quickly
/// and are deleted once a Page is selected.
model MetaOnboardingSession {
  id              String    @id @default(cuid())
  tenantId        String
  brandId         String
  userId          String
  userAccessToken String
  tokenType       String?
  tokenExpiresAt  DateTime?
  grantedScopes   String[]
  // Discovered pages (JSON) incl. per-page access tokens — server-only secrets.
  pages           Json
  createdAt       DateTime  @default(now())
  expiresAt       DateTime

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, brandId])
  @@map("meta_onboarding_sessions")
}

/// Raw inbound platform webhook events. Global (may not map to a tenant yet).
/// Stored for auditing; NO automatic moderation actions are taken from these.
model WebhookEvent {
  id             String   @id @default(cuid())
  platform       Platform
  eventType      String?
  signatureValid Boolean  @default(false)
  // V1.45C3 — the raw provider body (may contain personal data). NULLABLE so retention can MINIMIZE
  // it (set to NULL) once it is no longer operationally required: a processed row is never re-read,
  // a signature-invalid row never enters the processor, and any row older than the hard max-payload
  // age is minimized even if still pending. Bounded/security metadata (dedupeKey, signatureValid,
  // timestamps, links) is retained until the whole row is deleted by the global TTL purge.
  payload        Json?
  processed      Boolean  @default(false)
  // Whether the event mapped to a connected account (false = ignored/unmatched).
  matched        Boolean  @default(false)
  error          String?
  // V1.38.1 — stable dedup/replay key (the X-Hub-Signature-256 over the raw body).
  // A redelivered event has the same signature → the unique index rejects the replay.
  dedupeKey      String?  @unique
  // V1.45C1 — durable tenant/account linkage populated at PROCESSING time (never inferred from the
  // untrusted payload at deletion time). The tenant is resolved from the matched, active connected
  // account. `tenantId` is the purge key for tenant deletion (explicit purge before the tenant row
  // is removed) with ON DELETE Cascade as a defence-in-depth backstop — it is DELETED (never nulled)
  // with the tenant, so the association is never lost before the explicit purge. `connectedAccountId`
  // is informational (SetNull) so an account removal never blocks or orphan-nulls the tenant link.
  // Legacy pre-V1.45C1 rows have neither link and remain subject to future global retention (V1.45C3).
  tenantId           String?
  connectedAccountId String?
  receivedAt         DateTime @default(now())

  tenant           Tenant?           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  connectedAccount ConnectedAccount? @relation(fields: [connectedAccountId], references: [id], onDelete: SetNull)

  @@index([platform, receivedAt])
  @@index([processed])
  @@index([tenantId])
  @@index([connectedAccountId])
  // V1.45C3 — retention scans. `[receivedAt]` backs the global row-TTL purge (age scan). The partial
  // index for the payload-minimization scan (WHERE payload IS NOT NULL) is added in raw SQL in the
  // migration (Prisma cannot express a partial index).
  @@index([receivedAt])
  @@map("webhook_events")
}

// --- Content & reputation ----------------------------------------------------

model ContentItem {
  id                 String      @id @default(cuid())
  tenantId           String
  brandId            String
  connectedAccountId String
  platform           Platform
  kind               ContentKind
  externalId         String
  externalParentId   String?
  text               String
  authorExternalId   String?
  authorDisplayName  String?
  authorLocale       String?
  rating             Int?
  permalink          String?
  publishedAt        DateTime
  ingestedAt         DateTime    @default(now())

  tenant           Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  brand            Brand            @relation(fields: [brandId], references: [id], onDelete: Cascade)
  connectedAccount ConnectedAccount @relation(fields: [connectedAccountId], references: [id], onDelete: Cascade)
  reputationItem   ReputationItem?

  @@unique([connectedAccountId, externalId])
  @@index([tenantId])
  @@index([brandId])
  @@index([platform])
  @@map("content_items")
}

model ReputationItem {
  id               String           @id @default(cuid())
  tenantId         String
  brandId          String
  platform         Platform
  contentItemId    String           @unique
  status           ReputationStatus @default(new)
  priority         Priority         @default(normal)
  requiresApproval Boolean          @default(false)

  // V1.42 — Tamanor-side inbox workflow state (persisted, tenant-scoped, provider-neutral).
  // These are NEVER overwritten by provider ingest (ingest only touches provider content fields).
  isRead              Boolean             @default(false)
  archivedAt          DateTime?
  assignedToUserId    String?
  inboxWorkflowStatus InboxWorkflowStatus @default(new)

  // V1.44B — truthful AI processing state (written ONLY by the metering/classification service).
  // `processingReason` is a NORMALIZED allowlisted string — never a raw provider error.
  processingTier    ProcessingTier?
  processingStatus  InboxProcessingStatus @default(pending)
  processingReason  String?
  lastProcessedAt   DateTime?
  classifierVersion String?
  contentHash       String?

  // Embedded risk assessment (mirrors core ReputationRisk)
  riskLevel      RiskLevel @default(none)
  riskConfidence Float     @default(0)
  riskCategories String[]
  sentiment      Sentiment @default(neutral)
  riskRationale  String?
  riskEngine     String?
  assessedAt     DateTime?

  // Structured "why flagged" explanation (matchedTerms, riskSignals, action).
  riskExplanation Json?

  // Multilingual comment intelligence (best-effort; original text preserved).
  detectedLanguage        String?
  languageConfidence      Float?
  isMixedLanguage         Boolean @default(false)
  languageDetectionSource String? // rules | library | ai | unknown

  // Translation layer (no fake translation; provider off by default).
  translationStatus   String  @default("not_needed") // not_needed | translated | unavailable | failed
  translationProvider String  @default("none")
  translatedText      String?
  translatedToLocale  String?

  // Hybrid classification provenance.
  classificationMode String @default("rules_only") // rules_only | ai_assisted
  aiProvider         String @default("none")
  aiProviderStatus   String @default("skipped") // classified | skipped | unavailable | failed

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant        Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  brand         Brand                 @relation(fields: [brandId], references: [id], onDelete: Cascade)
  contentItem   ContentItem           @relation(fields: [contentItemId], references: [id], onDelete: Cascade)
  decisions     ModerationDecision[]
  incidentLinks IncidentRelatedItem[]
  // V1.42 — assignment (SetNull on user delete) + inbox labels/notes (composite tenant-safe FKs).
  assignedTo    User?                 @relation("InboxAssignee", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  inboxLabels   InboxItemLabel[]
  inboxNotes    InboxNote[]

  // V1.37.5 — enables composite (id, tenantId) foreign keys so a child can never
  // reference a ReputationItem belonging to a different tenant.
  @@unique([id, tenantId])
  @@index([tenantId])
  @@index([brandId, status])
  @@index([riskLevel])
  // V1.42 — inbox workflow query indexes.
  @@index([tenantId, isRead])
  @@index([tenantId, archivedAt])
  @@index([tenantId, assignedToUserId])
  @@index([tenantId, priority])
  @@index([tenantId, inboxWorkflowStatus])
  @@index([tenantId, processingStatus])
  // V1.43 — keyset pagination. The inbox lists ORDER BY createdAt DESC, id DESC within a tenant;
  // this composite lets a filtered page seek to the cursor and read rows in index order (no sort,
  // no seq scan), with cost independent of page depth. The second index serves the dominant
  // default/archived views, which additionally constrain archivedAt before the sort keys.
  @@index([tenantId, createdAt(sort: Desc), id(sort: Desc)])
  @@index([tenantId, archivedAt, createdAt(sort: Desc), id(sort: Desc)])
  // V1.51C — the inbox facet-count panel runs per-sentiment COUNTs per tenant. EXPLAIN-proven: this
  // turns the sentiment count from a Seq Scan (~986 buffers) into an Index-Only Scan (~37 buffers),
  // a ~150× execution-time reduction on a 10k-row table. The only index added this milestone.
  @@index([tenantId, sentiment])
  @@map("reputation_items")
}

// V1.42 — tenant-scoped inbox label. Unique normalized name per tenant. Deleting a label
// removes its join rows (Cascade) but leaves items intact.
model InboxLabel {
  id              String   @id @default(cuid())
  tenantId        String
  name            String
  normalizedName  String
  colorKey        String   @default("neutral")
  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items  InboxItemLabel[]

  @@unique([tenantId, normalizedName])
  @@unique([id, tenantId]) // enables the composite tenant-safe FK from the join table
  @@index([tenantId])
  @@map("inbox_labels")
}

// V1.42 — item↔label join. Composite (childId, tenantId)→(parent id, tenantId) FKs make a
// cross-tenant label assignment impossible at the DB level (same pattern as IncidentRelatedItem).
// No direct Tenant relation (tenantId is used by the composite FKs); rows are cleaned up via
// the parent Cascade. Deleting an item or a label removes the join row.
model InboxItemLabel {
  tenantId         String
  reputationItemId String
  labelId          String
  createdByUserId  String?
  createdAt        DateTime @default(now())

  reputationItem ReputationItem @relation(fields: [reputationItemId, tenantId], references: [id, tenantId], onDelete: Cascade)
  label          InboxLabel     @relation(fields: [labelId, tenantId], references: [id, tenantId], onDelete: Cascade)

  @@id([reputationItemId, labelId])
  @@index([tenantId])
  @@index([labelId, tenantId])
  @@map("inbox_item_labels")
}

// V1.42 — internal note on an inbox item. Composite tenant-safe FK to the item; author is a
// global User referenced with SetNull (a deleted user leaves the note with a null author, so
// history/audit value is preserved). Note bodies are plain text and never sent to a provider
// or logged in ops events.
model InboxNote {
  id               String    @id @default(cuid())
  tenantId         String
  reputationItemId String
  authorUserId     String?
  body             String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  reputationItem ReputationItem @relation(fields: [reputationItemId, tenantId], references: [id, tenantId], onDelete: Cascade)
  author         User?          @relation("InboxNoteAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, reputationItemId])
  @@map("inbox_notes")
}

// ===========================================================================================
// V1.44 — Usage metering & AI cost protection (additive, tenant-scoped, RLS-enforced).
// UsagePeriod counters are the SOURCE OF TRUTH; UsageEvent is an immutable append-only ledger.
// All money is INTEGER MICROS (BigInt) — never a float.
// ===========================================================================================

enum ProcessingTier {
  rules
  local
  paid
}

enum UsageEventStatus {
  reserved
  succeeded
  failed
  released
  denied
  cached
}

/// Per-tenant per-calendar-month (UTC) usage counters. These aggregate counters — NOT a scan of
/// the event ledger — are the authoritative quota state read on every reservation.
model UsagePeriod {
  id                String   @id @default(cuid())
  tenantId          String
  periodStart       DateTime // first instant of the UTC calendar month
  periodEnd         DateTime // first instant of the next UTC month (exclusive)
  plan              String
  basicUnitsUsed    Int      @default(0)
  premiumCallsUsed  Int      @default(0)
  premiumCostMicros BigInt   @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  events UsageEvent[]

  @@unique([tenantId, periodStart])
  @@unique([id, tenantId]) // enables the composite tenant-safe FK from UsageEvent
  @@index([tenantId, periodEnd])
  @@map("usage_periods")
}

/// Immutable append-only ledger of every metered operation. reputationItemId/contentItemId are
/// DENORMALIZED nullable references (no FK) so the ledger survives item deletion and stays
/// independent of item lifecycle; tenant isolation is enforced by RLS + the composite-FK'd
/// usagePeriodId. `idempotencyKey` is unique per tenant so a retry can never double-charge.
model UsageEvent {
  id                 String           @id @default(cuid())
  tenantId           String
  usagePeriodId      String
  reputationItemId   String?
  contentItemId      String?
  eventType          String
  processingTier     ProcessingTier
  provider           String?
  modelKey           String?
  units              Int              @default(0)
  reservedCostMicros BigInt           @default(0)
  actualCostMicros   BigInt?
  idempotencyKey     String
  status             UsageEventStatus
  reason             String?
  correlationId      String?
  createdAt          DateTime         @default(now())

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  usagePeriod UsagePeriod @relation(fields: [usagePeriodId, tenantId], references: [id, tenantId], onDelete: Cascade)

  @@unique([tenantId, idempotencyKey])
  @@index([tenantId, usagePeriodId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@map("usage_events")
}

/// Cached normalized AI result keyed by content version. A cache HIT never calls a paid provider
/// and never consumes a unit. Unique per (tenant, contentHash, modelKey, policyVersion).
model AiResultCache {
  id               String    @id @default(cuid())
  tenantId         String
  contentHash      String
  modelKey         String
  policyVersion    String
  normalizedResult Json
  createdAt        DateTime  @default(now())
  expiresAt        DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, contentHash, modelKey, policyVersion])
  @@index([tenantId, contentHash])
  @@map("ai_result_cache")
}

/// V1.44B — GLOBAL (cross-tenant, system-scope) paid-AI daily hard cap. NO tenantId and NO RLS by
/// design (mirrors the `leads` global table); reached ONLY via the narrow systemDb global-usage repo,
/// never from tenant-facing web code (boundary-enforced). Makes the daily call/cost hard cap
/// multi-instance safe via an atomic guarded UPDATE. Per-UTC-day, per-provider.
model GlobalAiUsagePeriod {
  id          String   @id @default(cuid())
  periodStart DateTime // first instant of the UTC day
  provider    String
  callsUsed   Int      @default(0)
  costMicros  BigInt   @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([periodStart, provider])
  @@map("global_ai_usage_periods")
}

/// Human feedback on a classification, scoped to a tenant+brand. Brand-local
/// learning only — never a global model update across brands.
model BrandRiskFeedback {
  id                 String   @id @default(cuid())
  tenantId           String
  brandId            String
  itemId             String?
  actorId            String?
  /// correct_risk | false_positive | false_negative | mark_safe | mark_risky |
  /// wrong_category | wrong_language | wrong_sentiment
  feedbackType       String
  originalRiskLevel  String?
  correctedRiskLevel String?
  originalCategory   String?
  correctedCategory  String?
  note               String?
  createdAt          DateTime @default(now())

  // V1.45C1 — cascade on tenant deletion (was tenantId-only, RLS-isolated).
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, brandId])
  @@index([brandId, feedbackType])
  @@map("brand_risk_feedback")
}

/// A brand-scoped risk memory rule the classifier applies (never global).
model BrandRiskMemoryRule {
  id               String   @id @default(cuid())
  tenantId         String
  brandId          String
  /// watch_phrase | block_phrase | allow_phrase | reduce_risk_pattern |
  /// increase_risk_pattern | competitor_phrase | crisis_phrase
  type             String
  phrase           String
  normalizedPhrase String
  language         String?
  /// low | medium | high | critical
  severity         String   @default("medium")
  /// manual | feedback | system
  source           String   @default("manual")
  isActive         Boolean  @default(true)
  createdBy        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // V1.45C1 — cascade on tenant deletion (was tenantId-only, RLS-isolated).
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, brandId, isActive])
  @@index([brandId, type])
  @@map("brand_risk_memory_rules")
}

/// Control Center policy — the unified source of truth for how a brand controls
/// each content category per platform/source. Modes: monitor|assist|approval|
/// autonomous. Autonomous is a gated candidate only (no live action by default).
model ControlPolicy {
  id                 String   @id @default(cuid())
  tenantId           String
  brandId            String
  connectedAccountId String?
  platform           String   @default("any") // any | facebook_page | ...
  sourceType         String   @default("comment") // comment|review|mention|message|post|rating
  category           String
  mode               String   @default("monitor") // monitor|assist|approval|autonomous
  allowedActions     String[]
  minConfidence      Float    @default(0.8)
  isActive           Boolean  @default(true)
  createdBy          String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // V1.45C1 — cascade on tenant deletion (was tenantId-only, RLS-isolated).
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([brandId, platform, sourceType, category])
  @@index([tenantId, brandId, isActive])
  @@map("control_policies")
}

/// What Guardora wants to do for an item, within policy. Never a live action by
/// default — see queueState. One active row per item.
model ActionQueueItem {
  id               String   @id @default(cuid())
  tenantId         String
  brandId          String
  itemId           String   @unique
  category         String
  confidence       Float    @default(0)
  proposedAction   String
  queueState       String // suggested|approval_required|approved|rejected|blocked_by_safety|dry_run|executed|failed|rollback_needed|monitor|no_action
  policyId         String?
  reason           String?
  safetyBlocked    Boolean  @default(false)
  wouldExecute     Boolean  @default(false)
  approvedByUserId String?
  rejectedByUserId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // V1.45C1 — cascade on tenant deletion (was tenantId-only, RLS-isolated).
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, brandId, queueState])
  @@map("action_queue_items")
}

/// A reputation incident (crisis / threat / coordinated attack / legal / safety).
model Incident {
  id             String    @id @default(cuid())
  tenantId       String
  brandId        String
  title          String
  category       String
  severity       String    @default("medium") // low|medium|high|critical
  status         String    @default("open") // open|resolved
  sourcePlatform String?
  // V1.37.5 — DENORMALIZED cache kept for compatibility. The referentially-integral
  // source of truth is `relatedItems` (IncidentRelatedItem join rows with real FKs).
  relatedItemIds String[]
  createdAt      DateTime  @default(now())
  resolvedAt     DateTime?

  // V1.45C1 — cascade on tenant deletion (was tenantId-only, RLS-isolated). Deleting a tenant
  // cascades its incidents, which in turn cascade their IncidentRelatedItem join rows.
  tenant       Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  relatedItems IncidentRelatedItem[]

  @@unique([id, tenantId])
  @@index([tenantId, brandId, status])
  @@map("incidents")
}

/**
 * V1.37.5 — referentially-integral normalization of Incident ⇄ ReputationItem. Replaces
 * the un-protectable `Incident.relatedItemIds String[]`. Composite (id, tenantId) FKs to
 * BOTH parents guarantee an incident can never link an item of a different tenant. Tenant-
 * scoped under RLS. Cascade: a link dies with either parent (a link has no standalone value).
 */
model IncidentRelatedItem {
  id               String   @id @default(cuid())
  tenantId         String
  incidentId       String
  reputationItemId String
  relationType     String   @default("related")
  createdAt        DateTime @default(now())

  incident       Incident       @relation(fields: [incidentId, tenantId], references: [id, tenantId], onDelete: Cascade)
  reputationItem ReputationItem @relation(fields: [reputationItemId, tenantId], references: [id, tenantId], onDelete: Cascade)

  @@unique([incidentId, reputationItemId])
  @@index([tenantId])
  @@index([reputationItemId])
  @@map("incident_related_items")
}

/// Per-brand Auto-Protect policy: what to do for each harmful-content category.
/// `auto_hide_shadow` computes a "would hide" decision only — NO platform action.
/// `auto_hide_live_reserved` is reserved for a future action-enable phase and must
/// never be selectable in the UI yet.
model BrandAutoProtectPolicy {
  id            String   @id @default(cuid())
  tenantId      String
  brandId       String
  category      String
  mode          String   @default("monitor") // monitor | approval | auto_hide_shadow | auto_hide_live_reserved
  minConfidence Float    @default(0.7)
  isActive      Boolean  @default(true)
  createdBy     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // V1.45C1 — cascade on tenant deletion (was tenantId-only, RLS-isolated).
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([brandId, category])
  @@index([tenantId, brandId, isActive])
  @@map("brand_auto_protect_policies")
}

/// Recorded Auto-Protect decision for an item. `would_auto_hide` is SHADOW ONLY —
/// nothing is hidden on the platform. One decision per item (latest wins).
model AutoProtectDecision {
  id              String   @id @default(cuid())
  tenantId        String
  brandId         String
  itemId          String   @unique
  matchedCategory String
  policyMode      String
  confidence      Float    @default(0)
  decision        String // no_action | monitor | requires_approval | would_auto_hide | blocked_by_safety
  reason          String?
  createdAt       DateTime @default(now())

  // V1.45C1 — cascade on tenant deletion (was tenantId-only, RLS-isolated).
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, brandId])
  @@index([brandId, decision])
  @@map("auto_protect_decisions")
}

/// Record of a controlled platform-action attempt (Facebook comment hide only).
/// Default env is fail-closed → status `blocked`/`dry_run`, never `executed`.
/// NEVER stores tokens/secrets or raw sensitive provider payloads.
model PlatformActionExecution {
  id                   String    @id @default(cuid())
  tenantId             String
  brandId              String
  // V1.37.5 — nullable so the FK to ReputationItem can ON DELETE SET NULL and keep
  // the execution as immutable history after the source item is deleted.
  itemId               String?
  queueItemId          String?
  policyId             String?
  connectedAccountId   String
  platform             String
  actionType           String // hide_comment
  requestedBy          String    @default("system") // system | user
  trigger              String    @default("autonomous") // approval | autonomous
  status               String // blocked | dry_run | executed | failed | rollback_pending | rolled_back
  reason               String?
  policyCategory       String?
  confidence           Float?
  externalCommentId    String?
  externalPostId       String?
  providerResponseCode String?
  providerErrorCode    String?
  providerErrorMessage String? // sanitized only
  createdAt            DateTime  @default(now())
  executedAt           DateTime?
  rolledBackAt         DateTime?

  // V1.45C1 — cascade on tenant deletion (was tenantId-only, RLS-isolated). The nullable
  // itemId/queueItemId history FKs (V1.37.5B, raw-SQL, ON DELETE SetNull) are unaffected.
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, brandId])
  @@index([status])
  @@index([itemId])
  @@map("platform_action_executions")
}

/// Observability record for an external provider call (translation | ai_risk).
/// Never stores tokens, secrets, or full sensitive payloads.
model ProviderCall {
  id        String   @id @default(cuid())
  type      String // translation | ai_risk
  provider  String
  status    String
  latencyMs Int      @default(0)
  errorCode String?
  itemId    String?
  tenantId  String?
  brandId   String?
  createdAt DateTime @default(now())

  // V1.45C1 — cascade on tenant deletion (was tenantId-only, RLS-isolated). Optional because a
  // provider call may be global/tenant-less (tenantId NULL) — those rows are unaffected by the FK.
  // The nullable itemId history FK (V1.37.5B, raw-SQL, ON DELETE SetNull) is unaffected.
  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([type, createdAt])
  @@index([tenantId])
  @@map("provider_calls")
}

model ModerationDecision {
  id               String           @id @default(cuid())
  tenantId         String
  brandId          String
  reputationItemId String
  action           ModerationAction
  status           DecisionStatus   @default(proposed)
  // Who proposed the action (ai / human / rule / system).
  proposedByKind   ActorKind
  proposedByUserId String?
  replyText        String?
  reason           String?
  confidence       Float?
  // Point-in-time AI risk assessment captured at proposal creation.
  riskSnapshot     Json?
  // Reviewer who approved / rejected / cancelled.
  reviewerUserId   String?
  reviewedAt       DateTime?
  executedAt       DateTime?
  failureReason    String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  brand          Brand          @relation(fields: [brandId], references: [id], onDelete: Cascade)
  reputationItem ReputationItem @relation(fields: [reputationItemId], references: [id], onDelete: Cascade)
  proposer       User?          @relation("DecisionProposer", fields: [proposedByUserId], references: [id])
  reviewer       User?          @relation("DecisionReviewer", fields: [reviewerUserId], references: [id])

  @@index([tenantId])
  @@index([brandId])
  @@index([reputationItemId])
  @@index([status])
  @@map("moderation_decisions")
}

// --- Rules, audit, reports ---------------------------------------------------

model BrandRule {
  id        String       @id @default(cuid())
  tenantId  String
  brandId   String
  name      String
  category  RuleCategory
  // Case-insensitive phrases matched against content text.
  phrases   String[]
  enabled   Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  brand  Brand  @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([brandId, enabled])
  @@map("brand_rules")
}

model AuditLog {
  id          String    @id @default(cuid())
  tenantId    String
  brandId     String?
  event       String
  actorKind   ActorKind
  actorUserId String?
  targetType  String?
  targetId    String?
  metadata    Json?
  createdAt   DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actor  User?  @relation(fields: [actorUserId], references: [id])

  @@index([tenantId, createdAt])
  @@index([event])
  @@map("audit_logs")
}

model ReportSnapshot {
  id          String   @id @default(cuid())
  tenantId    String
  brandId     String
  periodStart DateTime
  periodEnd   DateTime
  metrics     Json
  createdAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  brand  Brand  @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([brandId, periodEnd])
  @@map("report_snapshots")
}

enum LeadStatus {
  new
  contacted
  closed
}

/// Public inbound lead / contact request (Book a demo, Contact form).
/// Global — not tied to a tenant. Contains no secrets.
model Lead {
  id        String     @id @default(cuid())
  name      String
  email     String
  company   String?
  website   String?
  platforms String[]
  message   String?
  source    String     @default("book_demo")
  consent   Boolean    @default(false)
  status    LeadStatus @default(new)
  // Internal, team-only notes. Never shown publicly.
  notes     String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([status, createdAt])
  @@map("leads")
}

// ===========================================================================================
// V1.45C1 — GLOBAL, PRIVACY-SAFE tenant-deletion receipt. Deliberately has NO tenant foreign key
// (it must SURVIVE the tenant cascade as durable proof that a deletion occurred). Reached ONLY via
// the systemDb tenant-deletion service — never tenant-facing web code.
//
// It stores AGGREGATE, NON-PII facts only. It MUST NOT contain: tenant name, user email/name,
// tokens, webhook payloads, content text, provider response bodies, internal notes, or raw
// exception messages. `deletedTenantId` and `requestedByUserId` are OPAQUE cuids (internal
// handles, not personal data). `providerResultSummary` is a safe count-by-classification object.
// `failureClass` is a NORMALIZED allowlisted classification, never a raw error string.
// ===========================================================================================
model TenantDeletionReceipt {
  id                   String               @id @default(cuid())
  // Server-generated, unique — the idempotency key for the whole lifecycle. Two concurrent
  // requests converge on one operationId; a retry re-uses it; a stale one affects nothing.
  operationId          String               @unique
  deletedTenantId      String
  requestedByUserId    String?
  // "tenant_owner" | "platform_admin" — the authority that initiated deletion (never a tenant name).
  initiatedAuthority   String
  status               TenantDeletionStatus @default(requested)
  requestedAt          DateTime             @default(now())
  completedAt          DateTime?
  providerAccountCount Int                  @default(0)
  // Safe aggregate, e.g. { "revoked_provider": 0, "revoke_unsupported": 2, "clustersInvalidated": 1 }.
  providerResultSummary Json?
  webhookEventsPurged  Int                  @default(0)
  tenantRowDeleted     Boolean              @default(false)
  // Normalized failure classification (e.g. "provider_cleanup_failed", "cascade_failed"); never PII.
  failureClass         String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  @@index([deletedTenantId])
  @@index([status])
  @@map("tenant_deletion_receipts")
}

// V1.45C2 — who initiated a user identity erasure. `self` = the authenticated user erasing their own
// global identity; `platform_admin` = a V1.45A Platform Admin via the separate `user:delete` capability.
enum UserDeletionInitiator {
  self
  platform_admin
}

// ===========================================================================================
// V1.45C2 — GLOBAL, PRIVACY-SAFE user-identity deletion receipt. Deliberately has NO User foreign key
// (it MUST survive the hard-delete of the user as durable proof that an erasure occurred — the app's
// privacy policy promises GDPR erasure). Reached ONLY via the systemDb user-erasure service. Written
// in the SAME transaction as the User delete, so a receipt exists iff the erasure committed.
//
// It stores AGGREGATE, NON-PII facts only. It MUST NOT contain: email, name, tenant names, membership
// role names, platformRole, session hashes, tokens, IP/user-agent, content, or raw exception messages.
// `deletedUserId` and `requestedByUserId` are OPAQUE copied cuids (internal handles, no FK, not PII).
// No status field: a receipt is created ONLY on a committed erasure (a blocked erase writes nothing).
// ===========================================================================================
model UserDeletionReceipt {
  id                String                @id @default(cuid())
  // Server-generated, unique — the idempotency key. A converged concurrent/repeat erase reuses the
  // existing receipt rather than creating a second.
  operationId       String                @unique
  deletedUserId     String
  initiatedBy       UserDeletionInitiator
  requestedByUserId String?
  membershipCount   Int                   @default(0)
  sessionCount      Int                   @default(0)
  requestedAt       DateTime              @default(now())
  completedAt       DateTime?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@index([deletedUserId])
  @@map("user_deletion_receipts")
}

// V1.45C3 — how a global lead erasure targeted rows: by exact lead id, or by an exact normalized email.
enum LeadErasureMode {
  lead_id
  normalized_email
}

// ===========================================================================================
// V1.45C3 — GLOBAL, PRIVACY-SAFE lead-erasure receipt. Reached ONLY via the systemDb, Platform-Admin-
// authorized (`leads:erase`) lead-erasure service. Written in the SAME transaction as the lead delete.
//
// It stores AGGREGATE, NON-PII facts only. It MUST NOT contain: the erased lead id list, email or any
// email HASH (an unsalted email hash is a long-lived re-identification oracle — deliberately omitted),
// name, company, website, message, notes, tenant data, or raw exception messages. `requestedByUserId`
// is an OPAQUE cuid with no User FK (it survives a later actor erasure). `mode` records only WHICH
// exact-match strategy ran — never the target value itself.
// ===========================================================================================
model LeadErasureReceipt {
  id                String          @id @default(cuid())
  // Server-generated, unique — never client-selectable.
  operationId       String          @unique
  requestedByUserId String?
  mode              LeadErasureMode
  matchedCount      Int             @default(0)
  requestedAt       DateTime        @default(now())
  completedAt       DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@map("lead_erasure_receipts")
}
