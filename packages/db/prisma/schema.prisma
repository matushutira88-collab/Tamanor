// =============================================================================
// Guardora.ai — Prisma schema
//
// Multi-tenant, multi-brand, multi-platform reputation model.
// Mirrors @guardora/core domain types. Enums are kept in sync with core.
// No client passwords are stored. Connector tokens come from official OAuth only.
// =============================================================================

generator client {
  provider      = "prisma-client-js"
  // "native" keeps local macOS/Linux dev working; "rhel-openssl-3.0.x" is the Vercel
  // serverless runtime target — without it the Linux Query Engine is never generated and
  // Prisma fails to initialize in production (libquery_engine-rhel-openssl-3.0.x.so.node).
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Enums -------------------------------------------------------------------

enum Platform {
  facebook_page
  instagram_business
  youtube
  linkedin_company
  tiktok
  google_business
}

enum Role {
  owner
  admin
  analyst
  reviewer
  viewer
}

// V1.45A — GLOBAL platform-administration role, INDEPENDENT of tenant Role. Governs cross-tenant
// platform surfaces (e.g. the global prospect/leads admin). Default `none` — a tenant owner/admin
// has ZERO platform privilege. Never assigned by tenant UI, migration, or startup.
enum PlatformRole {
  none
  staff
  admin
}

// V1.66 — PER-USER onboarding lifecycle, stored on Membership (a user may belong to several tenants
// and their setup progress differs per workspace). `dismissed` is a resumable "not now", NEVER a lock.
enum OnboardingStatus {
  not_started
  in_progress
  completed
  dismissed
}

// V1.45C1 — tenant deletion lifecycle. `active` is the only state in which ordinary tenant
// activity (sessions, sync, webhook ingest, membership/provider changes) may proceed. Once a
// tenant transitions to `deleting`, every activity path fails closed (see assertTenantActive /
// the session guard) and only the deletion orchestrator + narrow system cleanup may touch it.
// The final tenant row is PHYSICALLY deleted at the end — there is no `deleted` state.
enum TenantDeletionState {
  active
  deleting
}

// V1.45C1 — status of a durable, PRIVACY-SAFE global deletion receipt (see TenantDeletionReceipt).
enum TenantDeletionStatus {
  requested
  completed
  failed
}

enum BrandStatus {
  active
  paused
  archived
}

enum BrandTone {
  professional
  friendly
  formal
  casual
  empathetic
}

enum ConnectorStatus {
  pending
  active
  mock_connected
  expired
  disconnected
  error
}

enum ConnectorMode {
  placeholder
  oauth_ready
  read_only
  action_disabled
}

enum ConnectorHealth {
  unknown
  healthy
  degraded
  error
}

enum SyncRunStatus {
  running
  completed
  failed
  // V1.37.4 — truthful sync outcomes.
  partial_success
  skipped_locked
  disconnected
  permission_missing
  rate_limited
  api_unavailable
  // V1.58.7 — the run did not complete because this worker LOST its lease (a newer worker took over)
  // or the process is shutting down. NEVER a success; distinct from `failed` (a real provider error).
  interrupted
}

enum ContentKind {
  comment
  reply
  review
  mention
  direct_message
}

enum ReputationStatus {
  new
  classified
  needs_approval
  actioned
  escalated
  ignored
  resolved
}

enum Priority {
  low
  normal
  high
  urgent
}

// V1.42 — internal inbox workflow status (Tamanor-side triage; NOT provider moderation state).
// `resolved` here NEVER implies a provider comment was hidden/deleted/replied.
enum InboxWorkflowStatus {
  new
  in_review
  action_required
  resolved
}

// V1.44B — truthful per-item AI processing state. NEVER implies fabricated sentiment/risk: a
// limit/disabled/failed status means the advanced tier did not run, not that analysis was invented.
enum InboxProcessingStatus {
  pending
  processed_rules
  processed_local
  processed_paid
  cached
  basic_limit_reached
  premium_limit_reached
  paid_ai_disabled
  failed
}

enum RuleCategory {
  blocked_words
  competitor_mentions
  crisis_keywords
  custom_phrases
}

enum RiskLevel {
  none
  low
  medium
  high
  critical
}

enum Sentiment {
  negative
  neutral
  positive
}

enum ModerationAction {
  none
  reply
  hide
  delete
  ignore
  mark_resolved
  escalate
}

enum ActorKind {
  ai
  human
  rule
  system
}

enum DecisionStatus {
  proposed
  approved
  rejected
  executed
  failed
  cancelled
}

// --- Identity & tenancy ------------------------------------------------------

model User {
  id                String       @id @default(cuid())
  email             String       @unique
  name              String?
  // V1.50A — self-service credential auth. Argon2id PHC string (never plaintext).
  // Nullable: dev-seed/E2E/future-OAuth users may have no local password.
  passwordHash      String?
  // V1.50C — email verification + password lifecycle.
  //   emailVerifiedAt: null until the email is verified (email/password) or set at creation
  //     for an OAuth provider-verified email. Gates verification-required product access.
  //   passwordChangedAt: set on every password reset; a session created before this is stale
  //     (defense-in-depth backstop in session hydrate, on top of explicit session revocation).
  emailVerifiedAt   DateTime?
  passwordChangedAt DateTime?
  locale            String       @default("en")
  // V1.45A — global platform-admin role (default least-privilege; independent of tenant Role).
  platformRole      PlatformRole @default(none)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  memberships             Membership[]
  oauthAccounts           OAuthAccount[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  proposed                ModerationDecision[]     @relation("DecisionProposer")
  reviewed                ModerationDecision[]     @relation("DecisionReviewer")
  auditLogs               AuditLog[]
  sessions                UserSession[]
  // V1.42 — inbox assignment + note authorship (both SetNull on user delete).
  assignedInboxItems      ReputationItem[]         @relation("InboxAssignee")
  inboxNotes              InboxNote[]              @relation("InboxNoteAuthor")
  // CS-C8 — Family guardian invitations this user accepted (SetNull on user delete).
  familyGuardianInvitationsAccepted FamilyGuardianInvitation[]

  @@map("users")
}

// V1.50B — external identity link for USER authentication (Google / Facebook Login).
// This is ONE user with potentially MANY login providers. It is entirely separate from
// the Meta Page/Business connector (ConnectedAccount / MetaOnboardingSession): it stores
// only the provider's opaque account id for sign-in, never a Page/business access token,
// and is never used to act on a platform. No provider access/refresh token is persisted —
// once the callback has read the account id + email, the token is discarded.
model OAuthAccount {
  id                String   @id @default(cuid())
  userId            String
  provider          String // "google" | "facebook" (USER login providers only)
  providerAccountId String // the provider's stable subject/user id (e.g. Google `sub`)
  createdAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // One external identity maps to at most one Tamanor user; a user has at most one link per provider.
  @@unique([provider, providerAccountId])
  @@unique([userId, provider])
  @@index([userId])
  @@map("oauth_accounts")
}

// V1.50C — one-time email verification token. Same fail-closed design as the session:
// a random raw token is emailed to the user; only its SHA-256 hash is stored here. A raw
// token NEVER touches the DB. One-time via an atomic guarded consume (consumedAt). Separate
// from UserSession — session tokens are never reused for email flows.
model EmailVerificationToken {
  id         String    @id @default(cuid())
  tokenHash  String    @unique
  userId     String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("email_verification_tokens")
}

// V1.50C — one-time password-reset token. Identical fail-closed, hash-at-rest design.
// A successful reset consumes the token, sets User.passwordChangedAt, and revokes every
// existing session for the user.
model PasswordResetToken {
  id         String    @id @default(cuid())
  tokenHash  String    @unique
  userId     String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

// V1.37.1 — opaque, DB-backed session. The cookie holds a random token; only
// its SHA-256 hash is stored here. A raw token is NEVER persisted. Sessions are
// fail-closed: expired/revoked/membership-missing → rejected.
model UserSession {
  id                String    @id @default(cuid())
  tokenHash         String    @unique
  userId            String
  activeTenantId    String
  createdAt         DateTime  @default(now())
  expiresAt         DateTime
  // V1.58.9 — hard ceiling a session can live regardless of activity (idle sliding never passes it).
  // NULLABLE for backward compatibility: pre-migration sessions have NULL and keep their `expiresAt`.
  absoluteExpiresAt DateTime?
  // V1.58.9 — persistent ("remember me") login → the longer absolute ceiling (SESSION_REMEMBER_ME_DAYS).
  rememberMe        Boolean   @default(false)
  // V1.58.9 — coarse device label for the "Active sessions" UI (never a token / raw IP / fingerprint).
  userAgentSummary  String?
  lastSeenAt        DateTime  @default(now())
  revokedAt         DateTime?
  rotatedFromId     String?

  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeTenant Tenant @relation(fields: [activeTenantId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([activeTenantId])
  @@index([expiresAt])
  @@map("user_sessions")
}

model Tenant {
  id                    String    @id @default(cuid())
  name                  String
  slug                  String    @unique
  plan                  String    @default("free")
  // CS-C0 — IMMUTABLE workspace kind. Every existing tenant is `business`. BUSINESS and
  // FAMILY data never share a tenant; capabilities are gated by kind on top of RLS.
  // Changed only via an internal migration procedure, never a client API call.
  workspaceKind         String    @default("business") // WorkspaceKind (business|family|child_safety_organization|internal)
  // V1.50A — self-service Free Trial. On registration: plan="free_trial" with a
  // 14-day window. Billing is out of scope (V1.50B+); these are informational only.
  trialStartsAt         DateTime?
  trialEndsAt           DateTime?
  // Optional company country captured at registration (no downstream logic yet).
  country               String?
  // V1.50B — onboarding state. NULL = onboarding pending (new workspace); set when the
  // owner finishes or skips the onboarding wizard, so it is shown once, not on every login.
  onboardingCompletedAt DateTime?
  // V1.50D — billing state (derived from Stripe via the webhook; the Subscription row holds the
  // detail). `billingStatus` is the truthful Stripe-aligned status; `accessState` is the central
  // application access decision. Defaults keep a trial-only tenant on full access.
  billingStatus         String    @default("no_subscription")
  accessState           String    @default("full_access")
  // V1.73 — INTERNAL Tamanor admin tenant. Authoritative, operator-set flag (never user-settable): when
  // true, the central resolvers grant unlimited access (no trial/billing block, unlimited usage/seats/
  // monitoring, export on) for sync, billing, usage, team and export alike. Set only by the internal-
  // tenant admin script / migration matching the exact internal email — never by registration.
  internalAccess        Boolean   @default(false)

  // V1.59 — tenant-level DEFAULT protection policy applied to accounts that do not override it.
  // Auto-hide defaults OFF (matches current production: no automatic Meta action unless enabled).
  defaultAutoHideEnabled       Boolean  @default(false)
  defaultAutoHideMode          String   @default("recommend") // recommend | manual_approval | automatic
  defaultAutoHideRiskThreshold String   @default("high") // medium | high | critical
  defaultAutoHideCategories    String[] @default([])
  defaultRequireManualApproval Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // V1.45C1 — deletion lifecycle. Default `active`; NON-NULL. A tenant is marked `deleting`
  // atomically at the start of the deletion lifecycle (see requestTenantDeletion). The
  // operation id is server-generated (never client-chosen) and unique so two concurrent
  // requests converge on one operation and a stale op-id can never affect another lifecycle.
  deletionState       TenantDeletionState @default(active)
  deletionRequestedAt DateTime?
  deletionOperationId String?             @unique

  memberships       Membership[]
  brands            Brand[]
  connectedAccounts ConnectedAccount[]
  contentItems      ContentItem[]
  reputationItems   ReputationItem[]
  decisions         ModerationDecision[]
  brandRules        BrandRule[]
  auditLogs         AuditLog[]
  reportSnapshots   ReportSnapshot[]
  metaOnboarding    MetaOnboardingSession[]
  inboxLabels       InboxLabel[]
  sessions          UserSession[]
  usagePeriods      UsagePeriod[]
  usageEvents       UsageEvent[]
  aiResultCache     AiResultCache[]
  subscription      Subscription?
  checkoutAttempts  StripeCheckoutAttempt[]

  // V1.45C1 — tenant-scoped tables that previously carried only a `tenantId` string (RLS-isolated
  // but NOT FK-linked). These now cascade on tenant deletion so the DB cascade graph is COMPLETE
  // and provable (no orphaned tenant-scoped rows survive a tenant delete).
  brandRiskFeedback        BrandRiskFeedback[]
  brandRiskMemoryRules     BrandRiskMemoryRule[]
  controlPolicies          ControlPolicy[]
  actionQueueItems         ActionQueueItem[]
  incidents                Incident[]
  brandAutoProtectPolicies BrandAutoProtectPolicy[]
  autoProtectDecisions     AutoProtectDecision[]
  platformActionExecutions PlatformActionExecution[]
  providerCalls            ProviderCall[]
  // V1.45C1 — durable tenant link for matched raw webhook events (explicit purge on deletion).
  webhookEvents            WebhookEvent[]
  notifications            Notification[]
  invites                  Invite[]

  // S0 — Security Suite (detection & response only; no new platform-mutation power).
  securityScoreSnapshots SecurityScoreSnapshot[]
  securityDetections     SecurityDetection[]
  brandProtectionCases   BrandProtectionCase[]

  // C1 — Cyberbullying Protection foundation (victim-centric; isolated from brand).
  protectedSubjects                  ProtectedSubject[]
  protectedSubjectRelationships      ProtectedSubjectRelationship[]
  // C2 — Evidence Foundation (local-only storage; immutable original + custody).
  storageObjects                     StorageObject[]
  incidentEvidence                   IncidentEvidence[]
  evidenceContextItems               EvidenceContextItem[]
  evidenceCustodyEvents              EvidenceCustodyEvent[]
  // C3 — Incident core (cyberbullying case graph over the single Incident ledger).
  cyberbullyingIncidentDetails       CyberbullyingIncidentDetail[]
  incidentTimelineEvents             IncidentTimelineEvent[]
  incidentParticipants               IncidentParticipant[]
  incidentDetectionLinks             IncidentDetectionLink[]
  // C5 — incident operations (assignment history + confidential reviewer notes).
  incidentReviewerNotes              IncidentReviewerNote[]
  incidentAssignmentEvents           IncidentAssignmentEvent[]
  // C6 — manual-report idempotency claims (double-submit protection).
  cyberbullyingReportSubmissions     CyberbullyingReportSubmission[]
  // C8 — detection triage overlay + append-only triage history.
  cyberbullyingDetectionTriage       CyberbullyingDetectionTriage[]
  cyberbullyingDetectionTriageEvents CyberbullyingDetectionTriageEvent[]
  // C9 — case management (protection plans + tasks).
  cyberbullyingProtectionPlans       CyberbullyingProtectionPlan[]
  cyberbullyingCaseTasks             CyberbullyingCaseTask[]
  // C10 — cyberbullying notifications + manual escalations. (Renamed from `notifications`
  // during the origin/main merge; the general product `notifications` relation lives above.)
  cyberbullyingNotifications         CyberbullyingNotification[]
  cyberbullyingEscalations           CyberbullyingEscalation[]
  // C11 — immutable compliance report snapshots.
  complianceReportSnapshots          ComplianceReportSnapshot[]
  // C12 — redaction / approval / export workflow.
  complianceRedactionDrafts          ComplianceRedactionDraft[]
  complianceRedactionRules           ComplianceRedactionRule[]
  complianceExportAuthorizations     ComplianceExportAuthorization[]
  complianceExportPackageManifests   ComplianceExportPackageManifest[]
  complianceApprovalHistoryEvents    ComplianceApprovalHistoryEvent[]

  // CS-C1 — Child Safety Family domain (FAMILY workspaces only; enforced by workspace guards + RLS).
  protectedProfiles               ProtectedProfile[]
  guardianRelationships           GuardianRelationship[]
  // CS-C2 — consent, guardian authority & safe-recipient assessment.
  guardianAuthorityRecords        GuardianAuthorityRecord[]
  consentRecords                  ConsentRecord[]
  safeRecipientAssessments        SafeRecipientAssessment[]
  // CS-C3 — safety signals.
  safetySignals                   SafetySignal[]
  // CS-C4 — recipient authorization decisions.
  recipientAuthorizationDecisions SafetyRecipientAuthorizationDecision[]
  // CS-C5 — internal deliveries.
  safetySignalDeliveries          SafetySignalDelivery[]
  // CS-C6 — workspace onboarding state (one per tenant).
  workspaceOnboardingState        WorkspaceOnboardingState?
  // CS-C8 — Family guardian invitations.
  familyGuardianInvitations       FamilyGuardianInvitation[]

  @@map("tenants")
}

// V1.50D — the tenant's subscription. Stores ONLY safe Stripe identifiers + billing state; never
// card numbers, CVC, payment methods, or raw payloads. One subscription per tenant (the active
// billing relationship). Written ONLY by the Stripe webhook processor from trusted Stripe data.
model Subscription {
  id                      String    @id @default(cuid())
  tenantId                String    @unique
  stripeCustomerId        String    @unique
  stripeSubscriptionId    String?   @unique
  stripePriceId           String?
  plan                    String // billing plan id (starter|growth|agency|enterprise|free_trial)
  billingInterval         String? // "monthly" | "yearly"
  status                  String // Stripe-aligned status
  currentPeriodStart      DateTime?
  currentPeriodEnd        DateTime?
  cancelAtPeriodEnd       Boolean   @default(false)
  canceledAt              DateTime?
  trialEndsAt             DateTime?
  latestInvoiceStatus     String?
  // V1.58.4 — out-of-order webhook guard: `created` time + terminality of the last APPLIED Stripe
  // billing event for this subscription aggregate. An older event must never overwrite newer state.
  lastStripeEventAt       DateTime?
  lastStripeEventTerminal Boolean   @default(false)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([stripeCustomerId])
  @@map("subscriptions")
}

/**
 * V1.57.3A — durable, tenant-scoped Checkout reservation. Exists BEFORE the Stripe network call and
 * stays authoritative until the attempt completes/expires/fails, closing the concurrency gap the
 * advisory-lock-only guard left open. A DB-enforced partial unique index (added in the SQL migration)
 * allows AT MOST ONE live attempt (status CREATING|OPEN) per tenant — independent of plan/interval.
 * This is concurrency + workflow state ONLY; the Subscription row remains the entitlement source.
 */
model StripeCheckoutAttempt {
  id                         String    @id @default(cuid())
  tenantId                   String
  // CREATING | OPEN | COMPLETED | EXPIRED | FAILED | ABANDONED
  status                     String
  requestedPlan              String
  requestedInterval          String
  stripePriceId              String
  stripeCheckoutSessionId    String?   @unique
  stripeCheckoutUrl          String?
  stripeCheckoutUrlExpiresAt DateTime?
  idempotencyKey             String    @unique
  createdByUserId            String?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt
  expiresAt                  DateTime
  completedAt                DateTime?
  failedAt                   DateTime?
  failureCode                String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([expiresAt])
  @@map("stripe_checkout_attempts")
}

// V1.50D — Stripe webhook idempotency + bounded audit. The Stripe event ID is UNIQUE, so a retried
// or replayed delivery is processed at most once. Stores a SAFE result classification only — never
// the full payment payload, card data, email, or Stripe response body. Old rows are purged on a
// bounded retention schedule (like webhook_events).
model StripeWebhookEvent {
  id            String    @id @default(cuid())
  stripeEventId String    @unique
  eventType     String
  result        String // "processed" | "ignored" | "failed"
  processedAt   DateTime?
  createdAt     DateTime  @default(now())

  @@index([createdAt])
  @@map("stripe_webhook_events")
}

model Membership {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String
  role      Role     @default(viewer)
  createdAt DateTime @default(now())

  // V1.66 — per-user × per-tenant onboarding progress. Deliberately on Membership, NOT User: the steps
  // (connect account, protect a brand, enable monitoring, first sync, first review) are all tenant-scoped,
  // and the `memberships` RLS policy is a direct `tenantId = current_app_tenant_id()` match, whereas the
  // `users` policy is an EXISTS over memberships (writable from ANY tenant the user belongs to).
  // NOTE: checklist STEP COMPLETION is never stored here — it is derived from live system state so it can
  // never drift. `onboardingChecklist` holds ONLY manual acknowledgements (allow-listed keys, no PII).
  onboardingStatus      OnboardingStatus @default(not_started)
  onboardingStartedAt   DateTime?
  onboardingCompletedAt DateTime?
  onboardingDismissedAt DateTime?
  onboardingVersion     Int              @default(1)
  onboardingStep        String?
  onboardingChecklist   Json?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // CS-C1 — a guardian membership may hold family guardian relationships (Family workspaces only).
  guardianRelationships GuardianRelationship[]
  // CS-C8 — invitations this membership has sent (Family workspaces only).
  familyGuardianInvitationsSent FamilyGuardianInvitation[]

  @@unique([userId, tenantId])
  // CS-C1 — composite unique enabling same-tenant composite FKs from GuardianRelationship
  // (guardianMembershipId, tenantId) → memberships(id, tenantId). No-op for Business tenants.
  @@unique([id, tenantId])
  @@index([tenantId])
  @@map("memberships")
}

// --- Brands & connectors -----------------------------------------------------

model Brand {
  id            String      @id @default(cuid())
  tenantId      String
  name          String
  displayName   String?
  defaultLocale String      @default("en")
  timezone      String      @default("UTC")
  defaultTone   BrandTone   @default(professional)
  status        BrandStatus @default(active)
  // V1.27 Production Safe Mode — per-brand kill switch. When true, NO live action.
  killSwitch    Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  tenant            Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  connectedAccounts ConnectedAccount[]
  contentItems      ContentItem[]
  reputationItems   ReputationItem[]
  decisions         ModerationDecision[]
  brandRules        BrandRule[]
  reportSnapshots   ReportSnapshot[]
  liveSafety        BrandLiveSafetySettings?

  // S0 — Security Suite (per-brand security signals; cascade with the brand).
  securityScoreSnapshots SecurityScoreSnapshot[]
  securityDetections     SecurityDetection[]
  brandProtectionCases   BrandProtectionCase[]

  @@index([tenantId])
  @@map("brands")
}

/// V1.27 Production Safe Mode — per-brand live-action safety envelope. Fail-closed
/// defaults: live off, autonomous off, low limits, high confidence, crisis lock on.
model BrandLiveSafetySettings {
  id                                 String   @id @default(cuid())
  tenantId                           String
  brandId                            String   @unique
  liveModeEnabled                    Boolean  @default(false)
  autonomousHideEnabled              Boolean  @default(false)
  approvalRequiredAboveDailyLimit    Boolean  @default(true)
  dailyAutoHideLimit                 Int      @default(10)
  hourlyAutoHideLimit                Int      @default(3)
  perCategoryDailyLimit              Int      @default(5)
  maxConsecutiveWithoutReview        Int      @default(5)
  minConfidenceForAutoHide           Float    @default(0.85)
  requireDryRunBeforeFirstLive       Boolean  @default(true)
  requireHumanApprovalForNewCategory Boolean  @default(true)
  rollbackRequiredBeforeAutonomy     Boolean  @default(true)
  crisisLockEnabled                  Boolean  @default(true)
  // Categories the brand has explicitly approved for autonomous auto-hide.
  approvedAutoHideCategories         String[]
  createdAt                          DateTime @default(now())
  updatedAt                          DateTime @updatedAt

  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("brand_live_safety_settings")
}

model ConnectedAccount {
  id                 String          @id @default(cuid())
  tenantId           String
  brandId            String
  platform           Platform
  status             ConnectorStatus @default(pending)
  mode               ConnectorMode   @default(placeholder)
  health             ConnectorHealth @default(unknown)
  externalId         String
  externalName       String?
  // Meta specifics
  pageId             String?
  igBusinessId       String?
  scopes             String[]
  // Permissions the user actually granted (may differ from requested scopes).
  grantedPermissions String[]
  // V1.27 Production Safe Mode — per-account kill switch. When true, NO live action.
  killSwitch         Boolean         @default(false)

  // V1.59 — per-account MONITORING + PROTECTION product model. Each Facebook Page and each Instagram
  // Professional account is an independent monitored account. `monitoringEnabled` (default true, matching
  // today's behaviour) gates whether Guardora watches it. Protection is resolved as: tenant defaults
  // UNLESS `protectionOverridden` is set, in which case the per-account fields below win. Auto-hide
  // defaults OFF; the global feature flag META_COMMENT_HIDE_FEATURE_ENABLED must also be on to ever act.
  monitoringEnabled      Boolean   @default(true)
  protectionOverridden   Boolean   @default(false)
  autoHideEnabled        Boolean   @default(false)
  autoHideMode           String    @default("recommend") // recommend | manual_approval | automatic
  autoHideRiskThreshold  String    @default("high") // medium | high | critical
  autoHideCategories     String[]  @default([])
  requireManualApproval  Boolean   @default(false)
  protectionConfiguredAt DateTime?

  // V1.27C Persistent Connection Manager — token/connection health, separate from
  // sync health. A hide never runs on an unverified token.
  connectionStatus           String    @default("connected") // connected|needs_reconnect|invalid_token|missing_permission|disabled_by_user|disconnected
  tokenHealth                String    @default("unknown") // unknown|ok|expiring_soon|expired|invalid|revoked
  lastTokenCheckAt           DateTime?
  lastTokenCheckResult       String?
  lastSuccessfulGraphCheckAt DateTime?
  lastReconnectAt            DateTime?
  lastPermissionCheckAt      DateTime?
  requiresReconnectReason    String?

  // ---------------------------------------------------------------------------
  // TOKENS — obtained via official OAuth ONLY (never passwords/scraping).
  // DEV NOTE: stored as plaintext in development for simplicity.
  // PRODUCTION REQUIREMENT: these columns MUST be encrypted at rest (KMS/envelope
  // encryption). Tokens are never returned to the UI and never logged.
  // See docs/SECURITY.md.
  // ---------------------------------------------------------------------------
  accessToken    String?
  longLivedToken String?
  refreshToken   String?
  tokenType      String?
  tokenExpiresAt DateTime?

  lastSyncedAt         DateTime?
  lastSuccessfulSyncAt DateTime?
  // Last external content cursor/timestamp seen (for incremental reads).
  lastCursor           String?
  lastError            String?
  lastErrorAt          DateTime?
  // Read-only sync retry/backoff state (no aggressive retry loops).
  syncAttempts         Int       @default(0)
  nextRetryAt          DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // V1.38 — canonical Meta asset linkage. An Instagram Business account references
  // its parent Facebook Page account. The FK (ON DELETE SET NULL) + a cross-tenant
  // trigger live in raw SQL (a composite SetNull would null the RLS tenantId) — same
  // pattern as the V1.37.5B history group. IG survives a Page removal with a null link.
  parentAccountId String?

  // V1.38.1 — last truthful Instagram content permission/availability state. One of
  // healthy|permission_missing|app_review_pending|business_verification_required|
  // token_expired|instagram_not_linked|professional_account_required|
  // account_not_discoverable|api_unavailable|rate_limited. Set ONLY from a real signal.
  contentPermissionState String?

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  brand         Brand          @relation(fields: [brandId], references: [id], onDelete: Cascade)
  contentItems  ContentItem[]
  syncRuns      SyncRun[]
  syncLeases    SyncLease[]
  // V1.45C1 — informational back-link from matched raw webhook events (ON DELETE SetNull).
  webhookEvents WebhookEvent[]

  @@unique([brandId, platform, externalId])
  @@index([tenantId])
  @@index([brandId])
  @@index([parentAccountId])
  @@map("connected_accounts")
}

model SyncRun {
  id                 String        @id @default(cuid())
  tenantId           String
  brandId            String
  connectedAccountId String
  status             SyncRunStatus @default(running)
  // Whether this run used the MOCK fallback (placeholder mode).
  mock               Boolean       @default(false)
  fetched            Int           @default(0)
  created            Int           @default(0)
  // V1.37.4 — resynced existing items whose provider content changed.
  updated            Int           @default(0)
  deduped            Int           @default(0)
  errors             Int           @default(0)
  error              String?
  durationMs         Int?
  // External content cursor/timestamp reached by this run, if any.
  cursor             String?
  startedAt          DateTime      @default(now())
  finishedAt         DateTime?

  connectedAccount ConnectedAccount @relation(fields: [connectedAccountId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([connectedAccountId, startedAt])
  @@map("sync_runs")
}

/**
 * V1.37.4 — account-level sync lease. At most ONE active lease per connected
 * account (unique on connectedAccountId), so a manual + scheduled sync of the same
 * account cannot run concurrently. The lease is DB-backed state (NOT an open DB
 * transaction): it has a TTL so a crashed holder never blocks the account forever —
 * an expired lease can be atomically taken over. Tenant-scoped under RLS.
 */
model SyncLease {
  id                 String   @id @default(cuid())
  tenantId           String
  connectedAccountId String   @unique
  holderId           String
  // V1.58.7 — monotonic FENCING token. Issued by the sync_lease_generation_seq DB sequence on every
  // acquire/takeover (never an app clock). Checked atomically on every critical write so a displaced
  // (expired) holder can never overwrite the state of the worker that took over. DEFAULT 0 = safe
  // floor for pre-migration rows and for the old worker (which never sets it) → backward compatible.
  generation         BigInt   @default(0)
  acquiredAt         DateTime @default(now())
  expiresAt          DateTime
  heartbeatAt        DateTime @default(now())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  connectedAccount ConnectedAccount @relation(fields: [connectedAccountId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([expiresAt])
  @@map("sync_leases")
}

/// Short-lived OAuth onboarding state between the Meta callback and Page
/// selection. Holds discovery results INCLUDING per-page access tokens.
///
/// SECURITY: `userAccessToken` and the tokens embedded in `pages` are SECRETS —
/// server-only, never returned to the UI, never logged. DEV stores plaintext;
/// PRODUCTION must encrypt at rest (see docs/SECURITY.md). Rows expire quickly
/// and are deleted once a Page is selected.
model MetaOnboardingSession {
  id              String    @id @default(cuid())
  tenantId        String
  brandId         String
  userId          String
  userAccessToken String
  tokenType       String?
  tokenExpiresAt  DateTime?
  grantedScopes   String[]
  // Discovered pages (JSON) incl. per-page access tokens — server-only secrets.
  pages           Json
  createdAt       DateTime  @default(now())
  expiresAt       DateTime

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, brandId])
  @@map("meta_onboarding_sessions")
}

/// Raw inbound platform webhook events. Global (may not map to a tenant yet).
/// Stored for auditing; NO automatic moderation actions are taken from these.
model WebhookEvent {
  id                 String   @id @default(cuid())
  platform           Platform
  eventType          String?
  signatureValid     Boolean  @default(false)
  // V1.45C3 — the raw provider body (may contain personal data). NULLABLE so retention can MINIMIZE
  // it (set to NULL) once it is no longer operationally required: a processed row is never re-read,
  // a signature-invalid row never enters the processor, and any row older than the hard max-payload
  // age is minimized even if still pending. Bounded/security metadata (dedupeKey, signatureValid,
  // timestamps, links) is retained until the whole row is deleted by the global TTL purge.
  payload            Json?
  processed          Boolean  @default(false)
  // Whether the event mapped to a connected account (false = ignored/unmatched).
  matched            Boolean  @default(false)
  error              String?
  // V1.38.1 — stable dedup/replay key (the X-Hub-Signature-256 over the raw body).
  // A redelivered event has the same signature → the unique index rejects the replay.
  dedupeKey          String?  @unique
  // V1.45C1 — durable tenant/account linkage populated at PROCESSING time (never inferred from the
  // untrusted payload at deletion time). The tenant is resolved from the matched, active connected
  // account. `tenantId` is the purge key for tenant deletion (explicit purge before the tenant row
  // is removed) with ON DELETE Cascade as a defence-in-depth backstop — it is DELETED (never nulled)
  // with the tenant, so the association is never lost before the explicit purge. `connectedAccountId`
  // is informational (SetNull) so an account removal never blocks or orphan-nulls the tenant link.
  // Legacy pre-V1.45C1 rows have neither link and remain subject to future global retention (V1.45C3).
  tenantId           String?
  connectedAccountId String?
  receivedAt         DateTime @default(now())

  tenant           Tenant?           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  connectedAccount ConnectedAccount? @relation(fields: [connectedAccountId], references: [id], onDelete: SetNull)

  @@index([platform, receivedAt])
  @@index([processed])
  @@index([tenantId])
  @@index([connectedAccountId])
  // V1.45C3 — retention scans. `[receivedAt]` backs the global row-TTL purge (age scan). The partial
  // index for the payload-minimization scan (WHERE payload IS NOT NULL) is added in raw SQL in the
  // migration (Prisma cannot express a partial index).
  @@index([receivedAt])
  @@map("webhook_events")
}

// --- Content & reputation ----------------------------------------------------

model ContentItem {
  id                 String      @id @default(cuid())
  tenantId           String
  brandId            String
  connectedAccountId String
  platform           Platform
  kind               ContentKind
  externalId         String
  externalParentId   String?
  text               String
  authorExternalId   String?
  authorDisplayName  String?
  authorLocale       String?
  rating             Int?
  permalink          String?
  publishedAt        DateTime
  ingestedAt         DateTime    @default(now())

  tenant           Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  brand            Brand            @relation(fields: [brandId], references: [id], onDelete: Cascade)
  connectedAccount ConnectedAccount @relation(fields: [connectedAccountId], references: [id], onDelete: Cascade)
  reputationItem   ReputationItem?

  @@unique([connectedAccountId, externalId])
  @@index([tenantId])
  @@index([brandId])
  @@index([platform])
  // V1.67 — dashboard/accounts metrics group content by account over a recent window
  // (WHERE tenantId + ingestedAt >= since). Without this the groupBy scans the tenant's whole history.
  @@index([tenantId, ingestedAt])
  @@map("content_items")
}

model ReputationItem {
  id               String           @id @default(cuid())
  tenantId         String
  brandId          String
  platform         Platform
  contentItemId    String           @unique
  status           ReputationStatus @default(new)
  priority         Priority         @default(normal)
  requiresApproval Boolean          @default(false)

  // V1.42 — Tamanor-side inbox workflow state (persisted, tenant-scoped, provider-neutral).
  // These are NEVER overwritten by provider ingest (ingest only touches provider content fields).
  isRead              Boolean             @default(false)
  archivedAt          DateTime?
  assignedToUserId    String?
  inboxWorkflowStatus InboxWorkflowStatus @default(new)

  // V1.44B — truthful AI processing state (written ONLY by the metering/classification service).
  // `processingReason` is a NORMALIZED allowlisted string — never a raw provider error.
  processingTier    ProcessingTier?
  processingStatus  InboxProcessingStatus @default(pending)
  processingReason  String?
  lastProcessedAt   DateTime?
  classifierVersion String?
  contentHash       String?

  // Embedded risk assessment (mirrors core ReputationRisk)
  riskLevel      RiskLevel @default(none)
  riskConfidence Float     @default(0)
  riskCategories String[]
  sentiment      Sentiment @default(neutral)
  riskRationale  String?
  riskEngine     String?
  assessedAt     DateTime?

  // Structured "why flagged" explanation (matchedTerms, riskSignals, action).
  riskExplanation Json?

  // Multilingual comment intelligence (best-effort; original text preserved).
  detectedLanguage        String?
  languageConfidence      Float?
  isMixedLanguage         Boolean @default(false)
  languageDetectionSource String? // rules | library | ai | unknown

  // Translation layer (no fake translation; provider off by default).
  translationStatus   String  @default("not_needed") // not_needed | translated | unavailable | failed
  translationProvider String  @default("none")
  translatedText      String?
  translatedToLocale  String?

  // Hybrid classification provenance.
  classificationMode String @default("rules_only") // rules_only | ai_assisted
  aiProvider         String @default("none")
  aiProviderStatus   String @default("skipped") // classified | skipped | unavailable | failed
  // V1.61 — admin-only classification breakdown: { callMode, rules, ai{verdict,tokens,...}, merged }.
  // NO comment text / prompt / raw model output — structured verdicts + provider metadata only. Nullable
  // (historical rows have none); surfaced solely in the admin diagnostics panel.
  aiDiagnostics      Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant        Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  brand         Brand                 @relation(fields: [brandId], references: [id], onDelete: Cascade)
  contentItem   ContentItem           @relation(fields: [contentItemId], references: [id], onDelete: Cascade)
  decisions     ModerationDecision[]
  incidentLinks IncidentRelatedItem[]
  // V1.42 — assignment (SetNull on user delete) + inbox labels/notes (composite tenant-safe FKs).
  assignedTo    User?                 @relation("InboxAssignee", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  inboxLabels   InboxItemLabel[]
  inboxNotes    InboxNote[]

  // V1.37.5 — enables composite (id, tenantId) foreign keys so a child can never
  // reference a ReputationItem belonging to a different tenant.
  @@unique([id, tenantId])
  @@index([tenantId])
  @@index([brandId, status])
  @@index([riskLevel])
  // V1.42 — inbox workflow query indexes.
  @@index([tenantId, isRead])
  @@index([tenantId, archivedAt])
  @@index([tenantId, assignedToUserId])
  @@index([tenantId, priority])
  @@index([tenantId, inboxWorkflowStatus])
  @@index([tenantId, processingStatus])
  // V1.43 — keyset pagination. The inbox lists ORDER BY createdAt DESC, id DESC within a tenant;
  // this composite lets a filtered page seek to the cursor and read rows in index order (no sort,
  // no seq scan), with cost independent of page depth. The second index serves the dominant
  // default/archived views, which additionally constrain archivedAt before the sort keys.
  @@index([tenantId, createdAt(sort: Desc), id(sort: Desc)])
  @@index([tenantId, archivedAt, createdAt(sort: Desc), id(sort: Desc)])
  // V1.51C — the inbox facet-count panel runs per-sentiment COUNTs per tenant. EXPLAIN-proven: this
  // turns the sentiment count from a Seq Scan (~986 buffers) into an Index-Only Scan (~37 buffers),
  // a ~150× execution-time reduction on a 10k-row table. The only index added this milestone.
  @@index([tenantId, sentiment])
  @@map("reputation_items")
}

// V1.42 — tenant-scoped inbox label. Unique normalized name per tenant. Deleting a label
// removes its join rows (Cascade) but leaves items intact.
model InboxLabel {
  id              String   @id @default(cuid())
  tenantId        String
  name            String
  normalizedName  String
  colorKey        String   @default("neutral")
  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items  InboxItemLabel[]

  @@unique([tenantId, normalizedName])
  @@unique([id, tenantId]) // enables the composite tenant-safe FK from the join table
  @@index([tenantId])
  @@map("inbox_labels")
}

// V1.42 — item↔label join. Composite (childId, tenantId)→(parent id, tenantId) FKs make a
// cross-tenant label assignment impossible at the DB level (same pattern as IncidentRelatedItem).
// No direct Tenant relation (tenantId is used by the composite FKs); rows are cleaned up via
// the parent Cascade. Deleting an item or a label removes the join row.
model InboxItemLabel {
  tenantId         String
  reputationItemId String
  labelId          String
  createdByUserId  String?
  createdAt        DateTime @default(now())

  reputationItem ReputationItem @relation(fields: [reputationItemId, tenantId], references: [id, tenantId], onDelete: Cascade)
  label          InboxLabel     @relation(fields: [labelId, tenantId], references: [id, tenantId], onDelete: Cascade)

  @@id([reputationItemId, labelId])
  @@index([tenantId])
  @@index([labelId, tenantId])
  @@map("inbox_item_labels")
}

// V1.42 — internal note on an inbox item. Composite tenant-safe FK to the item; author is a
// global User referenced with SetNull (a deleted user leaves the note with a null author, so
// history/audit value is preserved). Note bodies are plain text and never sent to a provider
// or logged in ops events.
model InboxNote {
  id               String    @id @default(cuid())
  tenantId         String
  reputationItemId String
  authorUserId     String?
  body             String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  reputationItem ReputationItem @relation(fields: [reputationItemId, tenantId], references: [id, tenantId], onDelete: Cascade)
  author         User?          @relation("InboxNoteAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, reputationItemId])
  @@map("inbox_notes")
}

// ===========================================================================================
// V1.44 — Usage metering & AI cost protection (additive, tenant-scoped, RLS-enforced).
// UsagePeriod counters are the SOURCE OF TRUTH; UsageEvent is an immutable append-only ledger.
// All money is INTEGER MICROS (BigInt) — never a float.
// ===========================================================================================

enum ProcessingTier {
  rules
  local
  paid
}

enum UsageEventStatus {
  reserved
  succeeded
  failed
  released
  denied
  cached
}

/// Per-tenant per-calendar-month (UTC) usage counters. These aggregate counters — NOT a scan of
/// the event ledger — are the authoritative quota state read on every reservation.
model UsagePeriod {
  id                String   @id @default(cuid())
  tenantId          String
  periodStart       DateTime // first instant of the UTC calendar month
  periodEnd         DateTime // first instant of the next UTC month (exclusive)
  plan              String
  basicUnitsUsed    Int      @default(0)
  premiumCallsUsed  Int      @default(0)
  premiumCostMicros BigInt   @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  events UsageEvent[]

  @@unique([tenantId, periodStart])
  @@unique([id, tenantId]) // enables the composite tenant-safe FK from UsageEvent
  @@index([tenantId, periodEnd])
  @@map("usage_periods")
}

/// Immutable append-only ledger of every metered operation. reputationItemId/contentItemId are
/// DENORMALIZED nullable references (no FK) so the ledger survives item deletion and stays
/// independent of item lifecycle; tenant isolation is enforced by RLS + the composite-FK'd
/// usagePeriodId. `idempotencyKey` is unique per tenant so a retry can never double-charge.
model UsageEvent {
  id                 String           @id @default(cuid())
  tenantId           String
  usagePeriodId      String
  reputationItemId   String?
  contentItemId      String?
  eventType          String
  processingTier     ProcessingTier
  provider           String?
  modelKey           String?
  units              Int              @default(0)
  reservedCostMicros BigInt           @default(0)
  actualCostMicros   BigInt?
  // V1.61.1 — provider-reported token usage for a finalized paid call (admin diagnostics join). Nullable;
  // historical rows and non-paid events stay NULL. NOT the source of cost (that is actualCostMicros).
  inputTokens        Int?
  outputTokens       Int?
  idempotencyKey     String
  status             UsageEventStatus
  reason             String?
  correlationId      String?
  createdAt          DateTime         @default(now())

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  usagePeriod UsagePeriod @relation(fields: [usagePeriodId, tenantId], references: [id, tenantId], onDelete: Cascade)

  @@unique([tenantId, idempotencyKey])
  @@index([tenantId, usagePeriodId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@map("usage_events")
}

/// Cached normalized AI result keyed by content version. A cache HIT never calls a paid provider
/// and never consumes a unit. Unique per (tenant, contentHash, modelKey, policyVersion).
model AiResultCache {
  id               String    @id @default(cuid())
  tenantId         String
  contentHash      String
  modelKey         String
  policyVersion    String
  normalizedResult Json
  createdAt        DateTime  @default(now())
  expiresAt        DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, contentHash, modelKey, policyVersion])
  @@index([tenantId, contentHash])
  @@map("ai_result_cache")
}

/// V1.44B — GLOBAL (cross-tenant, system-scope) paid-AI daily hard cap. NO tenantId and NO RLS by
/// design (mirrors the `leads` global table); reached ONLY via the narrow systemDb global-usage repo,
/// never from tenant-facing web code (boundary-enforced). Makes the daily call/cost hard cap
/// multi-instance safe via an atomic guarded UPDATE. Per-UTC-day, per-provider.
model GlobalAiUsagePeriod {
  id          String   @id @default(cuid())
  periodStart DateTime // first instant of the UTC day
  provider    String
  callsUsed   Int      @default(0)
  costMicros  BigInt   @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([periodStart, provider])
  @@map("global_ai_usage_periods")
}

/// Human feedback on a classification, scoped to a tenant+brand. Brand-local
/// learning only — never a global model update across brands.
model BrandRiskFeedback {
  id                 String   @id @default(cuid())
  tenantId           String
  brandId            String
  itemId             String?
  actorId            String?
  /// correct_risk | false_positive | false_negative | mark_safe | mark_risky |
  /// wrong_category | wrong_language | wrong_sentiment
  feedbackType       String
  originalRiskLevel  String?
  correctedRiskLevel String?
  originalCategory   String?
  correctedCategory  String?
  note               String?
  createdAt          DateTime @default(now())

  // V1.45C1 — cascade on tenant deletion (was tenantId-only, RLS-isolated).
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, brandId])
  @@index([brandId, feedbackType])
  @@map("brand_risk_feedback")
}

/// A brand-scoped risk memory rule the classifier applies (never global).
model BrandRiskMemoryRule {
  id               String   @id @default(cuid())
  tenantId         String
  brandId          String
  /// watch_phrase | block_phrase | allow_phrase | reduce_risk_pattern |
  /// increase_risk_pattern | competitor_phrase | crisis_phrase
  type             String
  phrase           String
  normalizedPhrase String
  language         String?
  /// low | medium | high | critical
  severity         String   @default("medium")
  /// manual | feedback | system
  source           String   @default("manual")
  isActive         Boolean  @default(true)
  createdBy        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // V1.45C1 — cascade on tenant deletion (was tenantId-only, RLS-isolated).
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, brandId, isActive])
  @@index([brandId, type])
  @@map("brand_risk_memory_rules")
}

/// Control Center policy — the unified source of truth for how a brand controls
/// each content category per platform/source. Modes: monitor|assist|approval|
/// autonomous. Autonomous is a gated candidate only (no live action by default).
model ControlPolicy {
  id                 String   @id @default(cuid())
  tenantId           String
  brandId            String
  connectedAccountId String?
  platform           String   @default("any") // any | facebook_page | ...
  sourceType         String   @default("comment") // comment|review|mention|message|post|rating
  category           String
  mode               String   @default("monitor") // monitor|assist|approval|autonomous
  allowedActions     String[]
  minConfidence      Float    @default(0.8)
  isActive           Boolean  @default(true)
  createdBy          String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // V1.45C1 — cascade on tenant deletion (was tenantId-only, RLS-isolated).
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([brandId, platform, sourceType, category])
  @@index([tenantId, brandId, isActive])
  @@map("control_policies")
}

/// What Guardora wants to do for an item, within policy. Never a live action by
/// default — see queueState. One active row per item.
model ActionQueueItem {
  id               String   @id @default(cuid())
  tenantId         String
  brandId          String
  itemId           String   @unique
  category         String
  confidence       Float    @default(0)
  proposedAction   String
  queueState       String // suggested|approval_required|approved|rejected|blocked_by_safety|dry_run|executed|failed|rollback_needed|monitor|no_action
  policyId         String?
  reason           String?
  safetyBlocked    Boolean  @default(false)
  wouldExecute     Boolean  @default(false)
  approvedByUserId String?
  rejectedByUserId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // V1.45C1 — cascade on tenant deletion (was tenantId-only, RLS-isolated).
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, brandId, queueState])
  @@map("action_queue_items")
}

/// A reputation incident (crisis / threat / coordinated attack / legal / safety).
model Incident {
  id             String    @id @default(cuid())
  tenantId       String
  // C3 (ADR-0001) — NULLABLE: a victim-centric cyberbullying incident may have no
  // brand. Brand incidents still set it. Plain denormalized column (no Brand FK).
  brandId        String?
  title          String
  // C3 (ADR-0001) — DOMAIN discriminator (IncidentCategory value). Default
  // `reputation` keeps every existing brand incident backward-compatible.
  // Distinct from `category` (free harm/descriptive category used by brand escalation).
  domain         String    @default("reputation")
  category       String
  severity       String    @default("medium") // low|medium|high|critical
  // C3 — canonical lifecycle (ADR-0002): open|under_review|acknowledged|confirmed|
  // action_required|resolved|dismissed|archived. `open`/`resolved` stay valid so
  // existing brand incidents are unaffected.
  status         String    @default("open")
  sourcePlatform String?
  // V1.37.5 — DENORMALIZED cache kept for compatibility. The referentially-integral
  // source of truth is `relatedItems` (IncidentRelatedItem join rows with real FKs).
  relatedItemIds String[]
  createdAt      DateTime  @default(now())
  resolvedAt     DateTime?

  // V1.45C1 — cascade on tenant deletion (was tenantId-only, RLS-isolated). Deleting a tenant
  // cascades its incidents, which in turn cascade their IncidentRelatedItem join rows.
  tenant       Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  relatedItems IncidentRelatedItem[]

  // C3 — cyberbullying case extension (one-to-one detail) + case graph.
  cyberbullyingDetail CyberbullyingIncidentDetail?
  timelineEvents      IncidentTimelineEvent[]
  participants        IncidentParticipant[]
  detectionLinks      IncidentDetectionLink[]
  evidence            IncidentEvidence[]
  reviewerNotes       IncidentReviewerNote[]
  assignmentEvents    IncidentAssignmentEvent[]
  reportSubmissions   CyberbullyingReportSubmission[]
  // C9 — case management (a case IS the incident): 1:1 protection plan + tasks.
  caseProtectionPlan  CyberbullyingProtectionPlan?
  caseTasks           CyberbullyingCaseTask[]
  // C10 — manual escalations on this incident.
  escalations         CyberbullyingEscalation[]
  // C11 — immutable compliance report snapshots of this incident.
  complianceReports   ComplianceReportSnapshot[]

  @@unique([id, tenantId])
  @@index([tenantId, brandId, status])
  @@index([tenantId, domain, status])
  @@map("incidents")
}

/**
 * V1.37.5 — referentially-integral normalization of Incident ⇄ ReputationItem. Replaces
 * the un-protectable `Incident.relatedItemIds String[]`. Composite (id, tenantId) FKs to
 * BOTH parents guarantee an incident can never link an item of a different tenant. Tenant-
 * scoped under RLS. Cascade: a link dies with either parent (a link has no standalone value).
 */
model IncidentRelatedItem {
  id               String   @id @default(cuid())
  tenantId         String
  incidentId       String
  reputationItemId String
  relationType     String   @default("related")
  createdAt        DateTime @default(now())

  incident       Incident       @relation(fields: [incidentId, tenantId], references: [id, tenantId], onDelete: Cascade)
  reputationItem ReputationItem @relation(fields: [reputationItemId, tenantId], references: [id, tenantId], onDelete: Cascade)

  @@unique([incidentId, reputationItemId])
  @@index([tenantId])
  @@index([reputationItemId])
  @@map("incident_related_items")
}

/// Per-brand Auto-Protect policy: what to do for each harmful-content category.
/// `auto_hide_shadow` computes a "would hide" decision only — NO platform action.
/// `auto_hide_live_reserved` is reserved for a future action-enable phase and must
/// never be selectable in the UI yet.
model BrandAutoProtectPolicy {
  id            String   @id @default(cuid())
  tenantId      String
  brandId       String
  category      String
  mode          String   @default("monitor") // monitor | approval | auto_hide_shadow | auto_hide_live_reserved
  minConfidence Float    @default(0.7)
  isActive      Boolean  @default(true)
  createdBy     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // V1.45C1 — cascade on tenant deletion (was tenantId-only, RLS-isolated).
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([brandId, category])
  @@index([tenantId, brandId, isActive])
  @@map("brand_auto_protect_policies")
}

/// Recorded Auto-Protect decision for an item. `would_auto_hide` is SHADOW ONLY —
/// nothing is hidden on the platform. One decision per item (latest wins).
model AutoProtectDecision {
  id              String   @id @default(cuid())
  tenantId        String
  brandId         String
  itemId          String   @unique
  matchedCategory String
  policyMode      String
  confidence      Float    @default(0)
  decision        String // no_action | monitor | requires_approval | would_auto_hide | blocked_by_safety
  reason          String?
  createdAt       DateTime @default(now())

  // V1.45C1 — cascade on tenant deletion (was tenantId-only, RLS-isolated).
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, brandId])
  @@index([brandId, decision])
  @@map("auto_protect_decisions")
}

/// Record of a controlled platform-action attempt (Facebook comment hide only).
/// Default env is fail-closed → status `blocked`/`dry_run`, never `executed`.
/// NEVER stores tokens/secrets or raw sensitive provider payloads.
model PlatformActionExecution {
  id                   String    @id @default(cuid())
  tenantId             String
  brandId              String
  // V1.37.5 — nullable so the FK to ReputationItem can ON DELETE SET NULL and keep
  // the execution as immutable history after the source item is deleted.
  itemId               String?
  queueItemId          String?
  policyId             String?
  connectedAccountId   String
  platform             String
  actionType           String // hide_comment
  requestedBy          String    @default("system") // system | user
  trigger              String    @default("autonomous") // approval | autonomous
  status               String // blocked | dry_run | executed | failed | rollback_pending | rolled_back
  reason               String?
  policyCategory       String?
  confidence           Float?
  externalCommentId    String?
  externalPostId       String?
  providerResponseCode String?
  providerErrorCode    String?
  providerErrorMessage String? // sanitized only
  createdAt            DateTime  @default(now())
  executedAt           DateTime?
  rolledBackAt         DateTime?

  // V1.45C1 — cascade on tenant deletion (was tenantId-only, RLS-isolated). The nullable
  // itemId/queueItemId history FKs (V1.37.5B, raw-SQL, ON DELETE SetNull) are unaffected.
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, brandId])
  @@index([status])
  @@index([itemId])
  @@map("platform_action_executions")
}

/// Observability record for an external provider call (translation | ai_risk).
/// Never stores tokens, secrets, or full sensitive payloads.
model ProviderCall {
  id        String   @id @default(cuid())
  type      String // translation | ai_risk
  provider  String
  status    String
  latencyMs Int      @default(0)
  errorCode String?
  itemId    String?
  tenantId  String?
  brandId   String?
  createdAt DateTime @default(now())

  // V1.45C1 — cascade on tenant deletion (was tenantId-only, RLS-isolated). Optional because a
  // provider call may be global/tenant-less (tenantId NULL) — those rows are unaffected by the FK.
  // The nullable itemId history FK (V1.37.5B, raw-SQL, ON DELETE SetNull) is unaffected.
  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([type, createdAt])
  @@index([tenantId])
  @@map("provider_calls")
}

model ModerationDecision {
  id               String           @id @default(cuid())
  tenantId         String
  brandId          String
  reputationItemId String
  action           ModerationAction
  status           DecisionStatus   @default(proposed)
  // Who proposed the action (ai / human / rule / system).
  proposedByKind   ActorKind
  proposedByUserId String?
  replyText        String?
  reason           String?
  confidence       Float?
  // Point-in-time AI risk assessment captured at proposal creation.
  riskSnapshot     Json?
  // Reviewer who approved / rejected / cancelled.
  reviewerUserId   String?
  reviewedAt       DateTime?
  executedAt       DateTime?
  failureReason    String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  brand          Brand          @relation(fields: [brandId], references: [id], onDelete: Cascade)
  reputationItem ReputationItem @relation(fields: [reputationItemId], references: [id], onDelete: Cascade)
  proposer       User?          @relation("DecisionProposer", fields: [proposedByUserId], references: [id])
  reviewer       User?          @relation("DecisionReviewer", fields: [reviewerUserId], references: [id])

  @@index([tenantId])
  @@index([brandId])
  @@index([reputationItemId])
  @@index([status])
  @@map("moderation_decisions")
}

// --- Rules, audit, reports ---------------------------------------------------

model BrandRule {
  id        String       @id @default(cuid())
  tenantId  String
  brandId   String
  name      String
  category  RuleCategory
  // Case-insensitive phrases matched against content text.
  phrases   String[]
  enabled   Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  brand  Brand  @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([brandId, enabled])
  @@map("brand_rules")
}

model AuditLog {
  id          String    @id @default(cuid())
  tenantId    String
  brandId     String?
  event       String
  actorKind   ActorKind
  actorUserId String?
  targetType  String?
  targetId    String?
  metadata    Json?
  createdAt   DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actor  User?  @relation(fields: [actorUserId], references: [id])

  @@index([tenantId, createdAt])
  @@index([event])
  // V1.67 — the inbox per-item activity timeline queries by (targetType, targetId IN pageIds); without
  // this it walks the tenant's audit history newest-first and filters.
  @@index([tenantId, targetType, targetId])
  @@map("audit_logs")
}

model ReportSnapshot {
  id          String   @id @default(cuid())
  tenantId    String
  brandId     String
  periodStart DateTime
  periodEnd   DateTime
  metrics     Json
  createdAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  brand  Brand  @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([brandId, periodEnd])
  @@map("report_snapshots")
}

// ===========================================================================
// Security Suite (S0 foundations) — detection & response only. No model here
// grants a new platform-mutation capability. Every table is tenant-scoped and
// added to the RLS strict-table policy in the accompanying migration. String
// columns (scope/kind/subjectType/status/source) mirror TS enums in
// @guardora/core `security.ts` (documented allowed values), matching the
// Incident model's pragmatic string convention; reused Prisma enums (RiskLevel,
// Platform) keep severity/platform type-safe.
// ===========================================================================

// Composite (append-only) posture score history, per tenant / brand / account.
// Live score is computed on demand; the worker persists periodic snapshots so
// trends survive. `subscores`/`inputs` carry the explainable breakdown.
model SecurityScoreSnapshot {
  id         String   @id @default(cuid())
  tenantId   String
  brandId    String?
  scope      String // tenant | brand | account (SecurityScoreScope)
  subjectId  String? // brandId or connectedAccountId when scope != tenant
  // S1 — score is NULLABLE: when coverage is below the minimum measurable
  // dimensions the composite is `insufficient_data` (null), never a fabricated 0.
  score      Int? // 0..100 composite, or null when insufficient_data
  status     String   @default("insufficient_data") // measured | insufficient_data
  subscores  Json // full breakdown: dimensions[], level, coverage, weightsRenormalized
  inputs     Json? // aggregated input snapshot for explainability (PII-minimal, no raw content)
  computedAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  brand  Brand? @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@unique([id, tenantId])
  @@index([tenantId, scope, computedAt])
  @@map("security_score_snapshots")
}

// Shared detection ledger for Account Takeover (S2) and Brand Protection (S4).
// INVARIANT: a detection never asserts a confirmed compromise. `severity` is a
// RiskLevel and the item is phrased as "possible account takeover"; detectors
// only ever create rows in `open`. Only a human review moves status to
// `confirmed`/`dismissed`/`resolved`.
model SecurityDetection {
  id               String    @id @default(cuid())
  tenantId         String
  brandId          String?
  subjectType      String // user | connected_account | brand (SecurityDetectionSubjectType)
  subjectId        String
  kind             String // SecurityDetectionKind (new_device, breach_exposure, mfa_disabled, ...)
  severity         RiskLevel @default(low)
  status           String    @default("open") // open | acknowledged | dismissed | confirmed | resolved
  // S2 — 0..100 deterministic strength of evidence (NOT a probability model). Null until a detector sets it.
  confidence       Int?
  // S2 — DetectionSource: auth | session | connector | action | manual. Null on legacy rows.
  source           String?
  // S2 — DEDUPLICATION. `dedupeKey` is the stable idempotency key (core detectionDedupeKey). A PARTIAL
  // UNIQUE index (raw SQL, in the migration) enforces at most ONE ACTIVE (open/acknowledged/confirmed)
  // detection per (tenantId, dedupeKey) — a recurring signal increments occurrenceCount + lastObservedAt
  // instead of piling up duplicate open rows. Terminal rows (dismissed/resolved) do NOT block a new one.
  dedupeKey        String? // null on legacy rows; excluded from the partial-unique guard
  // detectedAt IS the first-observed timestamp (set on create, never updated). lastObservedAt bumps on
  // each re-observation of the same active detection.
  lastObservedAt   DateTime  @default(now())
  occurrenceCount  Int       @default(1)
  // S2 — stable machine reason code for localized display (mirrors the score's issueCode pattern).
  reasonCode       String?
  // S2 — human note captured on dismiss/resolve (bounded + sanitized at the action layer; never a secret).
  resolutionNote   String?
  evidence         Json? // PII-minimal, sanitized signal evidence (never tokens/secrets/keys)
  detectedByEngine String? // detector/engine version for auditability
  detectedAt       DateTime  @default(now())
  reviewedByUserId String?
  reviewedAt       DateTime?
  resolvedAt       DateTime?

  tenant                    Tenant                              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  brand                     Brand?                              @relation(fields: [brandId], references: [id], onDelete: Cascade)
  // C3 — links to reviewed cases (a detection may be linked to incidents but can also stand alone).
  incidentLinks             IncidentDetectionLink[]
  // C8 — cyberbullying triage overlay (separate from the security `status`; never overloaded).
  cyberbullyingTriage       CyberbullyingDetectionTriage?
  cyberbullyingTriageEvents CyberbullyingDetectionTriageEvent[]

  @@unique([id, tenantId])
  @@index([tenantId, status, detectedAt])
  @@index([tenantId, subjectType, subjectId])
  @@index([tenantId, kind, status])
  @@map("security_detections")
}

// Brand-abuse / impersonation case register (S4). Sources are sanctioned only:
// inbound classified content, manual reporting, or an official API signal — no
// scraping. Escalatable to an Incident (S3).
model BrandProtectionCase {
  id                String    @id @default(cuid())
  tenantId          String
  brandId           String
  kind              String // impersonation | handle_squat | counterfeit | phishing | brand_attack (BrandProtectionKind)
  platform          Platform?
  subjectHandle     String?
  evidenceUrl       String?
  evidence          Json?
  source            String // detected | user_reported | api (BrandProtectionSource)
  severity          RiskLevel @default(medium)
  status            String    @default("open") // open | investigating | reported_to_platform | resolved | dismissed
  linkedDetectionId String?
  linkedIncidentId  String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  resolvedAt        DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  brand  Brand  @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@unique([id, tenantId])
  @@index([tenantId, status, createdAt])
  @@map("brand_protection_cases")
}

// ===========================================================================
// Cyberbullying Protection — C1 Protected Subject & Access Foundation.
// Victim-centric, tenant-scoped, ISOLATED from brand-reputation models (no
// brandId, no ContentItem/ReputationItem coupling). Minimal, NON-SENSITIVE
// foundation only: NO date-of-birth, address, phone, email, health, photos, or
// guardian data. String columns mirror @guardora/core enums. RLS ENABLE+FORCE +
// tenant_isolation added in the accompanying migration. Composite (id, tenantId)
// keys keep cross-tenant references structurally impossible.
// ===========================================================================

model ProtectedSubject {
  id               String   @id @default(cuid())
  tenantId         String
  // Opaque, tenant-scoped public identifier (never a real-world PII value).
  publicIdentifier String
  displayLabel     String
  subjectType      String // individual | other (ProtectedSubjectType)
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant          Tenant                         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  relationships   ProtectedSubjectRelationship[]
  // C3 — a protected subject may be the victim of cyberbullying incidents / a participant.
  incidentDetails CyberbullyingIncidentDetail[]
  participations  IncidentParticipant[]

  @@unique([id, tenantId])
  @@unique([tenantId, publicIdentifier])
  @@index([tenantId, active])
  @@map("protected_subjects")
}

model ProtectedSubjectRelationship {
  id                 String   @id @default(cuid())
  tenantId           String
  protectedSubjectId String
  relationshipType   String // trusted_contact | guardian | school | company (ProtectedSubjectRelationshipType)
  active             Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  tenant  Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // Composite (id, tenantId) FK — cross-tenant references are structurally impossible.
  subject ProtectedSubject @relation(fields: [protectedSubjectId, tenantId], references: [id, tenantId], onDelete: Cascade)

  @@unique([id, tenantId])
  @@index([tenantId, protectedSubjectId])
  @@map("protected_subject_relationships")
}

// ===========================================================================
// Cyberbullying Protection — C2 Evidence Foundation.
// LOCAL storage only (no cloud). Binary content NEVER in the DB — only a
// StorageObject reference. Original evidence is IMMUTABLE; only governance
// metadata (integrity/scan status, retention, legal hold, deletion) mutates.
// Custody is an append-only ledger, separate from AuditLog. String columns
// mirror @guardora/core cyberbullying-evidence enums. RLS ENABLE+FORCE +
// tenant_isolation added in the accompanying migration; composite (id, tenantId)
// FKs keep cross-tenant references structurally impossible.
// ===========================================================================

model StorageObject {
  id         String   @id @default(cuid())
  tenantId   String
  // Opaque LOCAL storage key (never a real path/PII; never a cloud URL).
  storageKey String
  sizeBytes  Int
  mimeType   String?
  createdAt  DateTime @default(now())

  tenant   Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  evidence IncidentEvidence[]

  @@unique([id, tenantId])
  @@index([tenantId, createdAt])
  @@map("storage_objects")
}

model IncidentEvidence {
  id                 String    @id @default(cuid())
  tenantId           String
  evidenceType       String // screenshot | message_text | file | link | other (EvidenceType)
  sourceType         String // user_upload | owned_account | api | other (EvidenceSourceType)
  captureMethod      String // user_upload | manual | api (EvidenceCaptureMethod)
  createdAt          DateTime  @default(now())
  capturedAt         DateTime
  // Opaque user reference (no FK — evidence may be system-captured; PII-minimal).
  submittedByUserId  String?
  // Reference columns (no FK yet): the composite (id, tenantId) FKs to Incident /
  // ProtectedSubject are wired when the case/subject linkage ships (C3+). Nullable
  // now; a plain column avoids a composite SetNull that cannot null a required tenantId.
  incidentId         String?
  protectedSubjectId String?
  storageObjectId    String
  mimeType           String?
  sizeBytes          Int
  // Immutable integrity facts.
  contentHash        String
  hashAlgorithm      String // sha256 (HashAlgorithm)
  // Mutable governance metadata.
  integrityStatus    String    @default("unverified") // unverified | verified | failed
  scanStatus         String    @default("pending_scan") // pending_scan | clean | infected | scan_failed
  retentionUntil     DateTime?
  legalHold          Boolean   @default(false)
  deletedAt          DateTime?

  tenant        Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  storageObject StorageObject          @relation(fields: [storageObjectId, tenantId], references: [id, tenantId], onDelete: Cascade)
  // C3 — composite tenant FK to the case ledger. Nullable (evidence may exist
  // before a case). Cascade: deleting an incident removes its linked evidence
  // (cyberbullying incidents are archived, not deleted; a SetNull-preserving
  // trigger is a future enhancement — composite SetNull can't null a required tenantId).
  incident      Incident?              @relation(fields: [incidentId, tenantId], references: [id, tenantId], onDelete: Cascade)
  contextItems  EvidenceContextItem[]
  custodyEvents EvidenceCustodyEvent[]

  @@unique([id, tenantId])
  @@index([tenantId, incidentId])
  @@index([tenantId, protectedSubjectId])
  @@map("incident_evidence")
}

model EvidenceContextItem {
  id               String   @id @default(cuid())
  tenantId         String
  evidenceId       String
  relation         String // before | primary | after (EvidenceContextRelation)
  sequencePosition Int      @default(0)
  createdAt        DateTime @default(now())

  tenant   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  evidence IncidentEvidence @relation(fields: [evidenceId, tenantId], references: [id, tenantId], onDelete: Cascade)

  @@unique([id, tenantId])
  @@index([tenantId, evidenceId])
  @@map("evidence_context_items")
}

// Append-only forensic chain-of-custody. No update/delete path.
model EvidenceCustodyEvent {
  id            String   @id @default(cuid())
  tenantId      String
  evidenceId    String
  eventType     String // captured | uploaded | verified | viewed_sensitive | redacted | deleted | retention_extended | legal_hold_enabled | legal_hold_removed (EvidenceCustodyEventType)
  actorUserId   String?
  actorRole     String?
  reason        String?
  previousHash  String?
  resultingHash String?
  createdAt     DateTime @default(now())

  tenant   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  evidence IncidentEvidence @relation(fields: [evidenceId, tenantId], references: [id, tenantId], onDelete: Cascade)

  @@unique([id, tenantId])
  @@index([tenantId, evidenceId, createdAt])
  @@map("evidence_custody_events")
}

// ===========================================================================
// Cyberbullying Protection — C3 Incident Core & Detection Binding.
// The Incident model above is the SINGLE case ledger; these are its cyberbullying
// extension + case graph. SecurityDetection stays the SINGLE signal ledger.
// All tenant-scoped, RLS ENABLE+FORCE, composite (id, tenantId) FKs.
// ===========================================================================

// One-to-one detail of an Incident (ADR-0001). NOT a second case ledger — it
// cannot exist without its Incident. `summary` is CONFIDENTIAL (never logged).
model CyberbullyingIncidentDetail {
  id                            String   @id @default(cuid())
  tenantId                      String
  incidentId                    String
  protectedSubjectId            String
  reportSource                  String // manual_report | detection (IncidentReportSource)
  summary                       String // CONFIDENTIAL — never written to logs
  // Neutral, non-accusatory: an ALLEGED actor label, never a confirmed attacker.
  allegedActorLabel             String?
  allegedActorExternalReference String?
  // C5 — the ONE primary reviewer currently assigned (opaque user reference, no FK).
  // The append-only IncidentAssignmentEvent log is the who/when/why history.
  assignedReviewerUserId        String?
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt

  tenant   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  incident Incident         @relation(fields: [incidentId, tenantId], references: [id, tenantId], onDelete: Cascade)
  subject  ProtectedSubject @relation(fields: [protectedSubjectId, tenantId], references: [id, tenantId], onDelete: Cascade)

  @@unique([id, tenantId])
  @@unique([incidentId, tenantId]) // one-to-one: at most one detail per incident
  @@index([tenantId, protectedSubjectId])
  @@map("cyberbullying_incident_details")
}

// Append-only, human-readable case timeline (distinct from AuditLog + custody).
model IncidentTimelineEvent {
  id          String   @id @default(cuid())
  tenantId    String
  incidentId  String
  eventType   String // IncidentTimelineEventType
  actorUserId String? // null only for system events
  reason      String?
  metadata    Json? // sanitized — no evidence content / secrets / PII
  createdAt   DateTime @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  incident Incident @relation(fields: [incidentId, tenantId], references: [id, tenantId], onDelete: Cascade)

  @@unique([id, tenantId])
  @@index([tenantId, incidentId, createdAt])
  @@map("incident_timeline_events")
}

// A person's role in an incident. `alleged_actor` is neutral — never a confirmed
// attacker without human review. No Tamanor account is required (externalReference).
model IncidentParticipant {
  id                 String   @id @default(cuid())
  tenantId           String
  incidentId         String
  role               String // protected_subject | reporter | alleged_actor | reviewer | trusted_contact (IncidentParticipantRole)
  protectedSubjectId String?
  userId             String? // opaque user reference (no FK)
  externalReference  String? // sanitized external identifier
  createdAt          DateTime @default(now())

  tenant   Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  incident Incident          @relation(fields: [incidentId, tenantId], references: [id, tenantId], onDelete: Cascade)
  // Cascade (not SetNull): a composite FK cannot null the required tenantId. A
  // subject is normally anonymized, not deleted; deletion removes its participations.
  subject  ProtectedSubject? @relation(fields: [protectedSubjectId, tenantId], references: [id, tenantId], onDelete: Cascade)

  @@unique([id, tenantId])
  // Prevent a duplicate participant with the SAME identity in one incident.
  @@unique([incidentId, role, protectedSubjectId, userId, externalReference])
  @@index([tenantId, incidentId])
  @@map("incident_participants")
}

// Explicit many-to-many link between a reviewed case and security signals. A link
// NEVER confirms the incident. Unique per (incident, detection).
model IncidentDetectionLink {
  id                  String   @id @default(cuid())
  tenantId            String
  incidentId          String
  securityDetectionId String
  linkedByUserId      String? // null only for a trusted system actor
  linkReason          String
  createdAt           DateTime @default(now())

  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  incident  Incident          @relation(fields: [incidentId, tenantId], references: [id, tenantId], onDelete: Cascade)
  detection SecurityDetection @relation(fields: [securityDetectionId, tenantId], references: [id, tenantId], onDelete: Cascade)

  @@unique([id, tenantId])
  @@unique([incidentId, securityDetectionId]) // idempotent link; same-tenant guaranteed by composite FKs
  @@index([tenantId, incidentId])
  @@map("incident_detection_links")
}

// C5 — append-only, CONFIDENTIAL internal reviewer note. No edit, no delete: the
// record is immutable once written. The body is never logged and is never shown to
// a protected subject (read requires cyberbullying:review). Not evidence — plain
// text, never a blob / storage object.
model IncidentReviewerNote {
  id           String   @id @default(cuid())
  tenantId     String
  incidentId   String
  authorUserId String // opaque user reference (no FK); the note's author
  body         String // CONFIDENTIAL — never written to logs / audit / timeline
  createdAt    DateTime @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  incident Incident @relation(fields: [incidentId, tenantId], references: [id, tenantId], onDelete: Cascade)

  @@unique([id, tenantId])
  @@index([tenantId, incidentId, createdAt])
  @@map("incident_reviewer_notes")
}

// C5 — append-only assignment history for the single primary reviewer. Records who
// assigned whom, when, and why. `assigneeUserId` is null for an unassign;
// `previousAssigneeUserId` is null for the first assignment. Immutable.
model IncidentAssignmentEvent {
  id                     String   @id @default(cuid())
  tenantId               String
  incidentId             String
  action                 String // assigned | reassigned | unassigned (IncidentAssignmentAction)
  assigneeUserId         String? // null for unassign
  previousAssigneeUserId String? // null for the first assignment
  assignedByUserId       String // the actor who performed the assignment
  reason                 String?
  createdAt              DateTime @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  incident Incident @relation(fields: [incidentId, tenantId], references: [id, tenantId], onDelete: Cascade)

  @@unique([id, tenantId])
  @@index([tenantId, incidentId, createdAt])
  @@map("incident_assignment_events")
}

// C6 — manual-report idempotency claim. Guarantees one browser submit creates at
// most one incident: the claim is inserted as the LAST write of the create
// transaction, so a duplicate key (double-click / resubmit) hits the unique index
// and rolls the whole creation back — no orphan incident. Tenant + user scoped;
// the raw key is server/client-only and never shown in the UI. Not the incident
// itself — just a durable dedup marker mapping key → created incident.
model CyberbullyingReportSubmission {
  id             String   @id @default(cuid())
  tenantId       String
  userId         String // the reporter (opaque reference, no FK)
  idempotencyKey String
  incidentId     String
  createdAt      DateTime @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  incident Incident @relation(fields: [incidentId, tenantId], references: [id, tenantId], onDelete: Cascade)

  @@unique([id, tenantId])
  // One incident per (tenant, user, key) — the double-submit guard. Tenant-scoped
  // so a key can never collide across tenants.
  @@unique([tenantId, userId, idempotencyKey])
  @@index([tenantId, incidentId])
  @@map("cyberbullying_report_submissions")
}

// C8 — cyberbullying TRIAGE state of an existing SecurityDetection. NOT a second
// detection model: a 1:1 overlay that lets a human triage a security signal into
// the cyberbullying workflow (new → under_review → false_positive | ignored |
// linked_to_incident, reopenable from false_positive/ignored). The security-domain
// `SecurityDetection.status` is never touched. Detections are never deleted.
model CyberbullyingDetectionTriage {
  id                  String   @id @default(cuid())
  tenantId            String
  securityDetectionId String
  status              String   @default("new") // CyberbullyingDetectionStatus
  incidentId          String? // set when linked_to_incident (plain ref; the C3 link is the FK-backed source of truth)
  reviewedByUserId    String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  detection SecurityDetection @relation(fields: [securityDetectionId, tenantId], references: [id, tenantId], onDelete: Cascade)

  @@unique([id, tenantId])
  @@unique([securityDetectionId, tenantId]) // one triage row per detection
  @@index([tenantId, status])
  @@map("cyberbullying_detection_triage")
}

// C8 — append-only detection-triage timeline / status history. No update/delete.
model CyberbullyingDetectionTriageEvent {
  id                  String   @id @default(cuid())
  tenantId            String
  securityDetectionId String
  eventType           String // CyberbullyingDetectionEventType
  actorUserId         String?
  reason              String?
  metadata            Json? // sanitized — ids/status only, never signal evidence
  createdAt           DateTime @default(now())

  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  detection SecurityDetection @relation(fields: [securityDetectionId, tenantId], references: [id, tenantId], onDelete: Cascade)

  @@unique([id, tenantId])
  @@index([tenantId, securityDetectionId, createdAt])
  @@map("cyberbullying_detection_triage_events")
}

// C9 — Protection Plan. A 1:1 case-management extension of an Incident (a case IS
// the incident — NOT a second case model). All fields are set MANUALLY by a human
// reviewer; nothing here is inferred or automatic. Milestones are nullable
// timestamps toggled by hand. Free-text (objective/notes) is CONFIDENTIAL — never
// written to the timeline or audit.
model CyberbullyingProtectionPlan {
  id                           String    @id @default(cuid())
  tenantId                     String
  incidentId                   String
  riskLevel                    String? // CaseRiskLevel (low|medium|high|critical) — null until set
  // C10 — when riskLevel became CRITICAL (start of the critical-risk-response SLA);
  // null unless currently critical. Set/cleared by the manual protection-plan update.
  criticalRiskSetAt            DateTime?
  protectionStatus             String    @default("not_started") // CaseProtectionStatus
  objective                    String?
  notes                        String?
  nextReviewAt                 DateTime?
  lastReviewAt                 DateTime?
  followUpNotes                String?
  // Manually-toggled milestones (null = not achieved).
  milestoneInitialReviewAt     DateTime?
  milestoneEvidenceCollectedAt DateTime?
  milestoneVictimContactedAt   DateTime?
  milestoneProtectionActiveAt  DateTime?
  milestoneResolvedAt          DateTime?
  createdAt                    DateTime  @default(now())
  updatedAt                    DateTime  @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  incident Incident @relation(fields: [incidentId, tenantId], references: [id, tenantId], onDelete: Cascade)

  @@unique([id, tenantId])
  @@unique([incidentId, tenantId]) // one protection plan per incident
  @@index([tenantId, protectionStatus])
  @@map("cyberbullying_protection_plans")
}

// C9 — Case Task. Belongs to an Incident (no standalone task centre). Status
// transitions are validated server-side. Title/description CONTENT never enters the
// audit/timeline.
model CyberbullyingCaseTask {
  id              String    @id @default(cuid())
  tenantId        String
  incidentId      String
  title           String
  description     String?
  status          String    @default("todo") // CaseTaskStatus (todo|in_progress|done|cancelled)
  assigneeUserId  String? // opaque user reference (no FK)
  dueDate         DateTime?
  createdByUserId String
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  incident Incident @relation(fields: [incidentId, tenantId], references: [id, tenantId], onDelete: Cascade)

  @@unique([id, tenantId])
  @@index([tenantId, incidentId, status])
  @@map("cyberbullying_case_tasks")
}

// C10 — cyberbullying-scoped internal, in-app notification (tenant-scoped, recipient-based).
// Renamed from `Notification` (table `notifications`) to `CyberbullyingNotification`
// (table `cyberbullying_notifications`) during the origin/main merge: origin/main's V1.70
// introduced its OWN general product `Notification` (table `notifications`) with a different
// shape, so the two coexist as distinct domains. The DB stores a `type` (translation-key
// mapping happens in the UI — NEVER a rendered localized string) + SANITIZED metadata only:
// never notes/summary/filename/actor reference. The recipient MUST be a member of the same
// tenant. `deduplicationKey` makes a repeated evaluation idempotent while a new relevant
// state creates a new row.
model CyberbullyingNotification {
  id               String    @id @default(cuid())
  tenantId         String
  recipientUserId  String
  type             String
  severity         String // info | attention | urgent (NotificationSeverity)
  entityType       String // NotificationEntityType
  entityId         String
  incidentId       String? // plain ref (general model): the safe CTA target when set
  deduplicationKey String
  metadata         Json? // sanitized — ids/enum values only
  createdAt        DateTime  @default(now())
  readAt           DateTime?
  dismissedAt      DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([id, tenantId])
  // Dedup: one live notification per (tenant, recipient, key). A changed due date ⇒
  // a different key ⇒ a new notification; cross-tenant collision is impossible.
  // Explicit `map:` names: the default names exceed Postgres's 63-char identifier
  // limit once the table is `cyberbullying_notifications`, so name them deterministically.
  @@unique([tenantId, recipientUserId, deduplicationKey], map: "cyberbullying_notifications_dedup_key")
  @@index([tenantId, recipientUserId, readAt, createdAt], map: "cyberbullying_notifications_unread_idx")
  @@index([tenantId, incidentId])
  @@map("cyberbullying_notifications")
}

// C10 — Manual incident escalation. An explicit, auditable human step marking an
// incident as needing higher attention. It NEVER changes the incident lifecycle,
// the manual risk level, milestones, tasks, or assignments. The confidential `note`
// is never written to the timeline, audit, or a notification payload.
model CyberbullyingEscalation {
  id                String    @id @default(cuid())
  tenantId          String
  incidentId        String
  status            String    @default("active") // active | resolved | cancelled (EscalationStatus)
  severity          String // attention | urgent (EscalationSeverity)
  reasonCode        String // EscalationReason (enum allowlist)
  note              String? // CONFIDENTIAL — never logged / never in a notification
  escalatedByUserId String
  escalatedAt       DateTime  @default(now())
  targetUserId      String?
  targetRole        String?
  resolvedAt        DateTime?
  resolvedByUserId  String?
  resolutionCode    String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  incident Incident @relation(fields: [incidentId, tenantId], references: [id, tenantId], onDelete: Cascade)

  @@unique([id, tenantId])
  @@index([tenantId, incidentId, status])
  @@map("cyberbullying_escalations")
}

// C11 — IMMUTABLE compliance report snapshot: an append-only, versioned, hashed
// snapshot of an incident at a point in time. NOT a second case model — the incident
// stays the canonical case. Immutability is enforced at the DB privilege level: the
// app role is granted SELECT + INSERT only (no UPDATE/DELETE) in the migration, so a
// snapshot can never be edited or deleted by the application. The payload holds only
// SANITIZED metadata (never evidence content, notes, or subject PII). A general
// foundation (reusable), used in C11 only for cyberbullying.
model ComplianceReportSnapshot {
  id                      String    @id @default(cuid())
  tenantId                String
  incidentId              String
  reportType              String // ComplianceReportType
  version                 Int
  schemaVersion           String
  status                  String    @default("ready") // ComplianceReportStatus (append-only)
  redactionState          String    @default("unredacted_internal") // RedactionState
  generatedByUserId       String
  generatedAt             DateTime  @default(now())
  sourceIncidentUpdatedAt DateTime?
  snapshotHash            String
  previousSnapshotHash    String?
  snapshotPayload         Json
  idempotencyKey          String?
  // C12 — redaction provenance (set only on a REDACTED snapshot; null on originals).
  sourceReportId          String?
  sourceSnapshotHash      String?
  redactionDraftId        String?
  redactionRuleSetHash    String?
  approvedByUserId        String?
  approvedAt              DateTime?
  redactionSummary        Json?
  createdAt               DateTime  @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  incident Incident @relation(fields: [incidentId, tenantId], references: [id, tenantId], onDelete: Cascade)

  @@unique([id, tenantId], map: "crs_id_tenant_key")
  // Version is server-computed and unique per (tenant, incident, reportType).
  @@unique([tenantId, incidentId, reportType, version], map: "crs_tenant_incident_type_version_key")
  // Idempotency: one report per (tenant, user, incident, reportType, key). NULL keys
  // are distinct in Postgres, so keyless creates never collide.
  @@unique([tenantId, generatedByUserId, incidentId, reportType, idempotencyKey], map: "crs_tenant_user_incident_type_idem_key")
  @@index([tenantId, incidentId, reportType, version], map: "crs_tenant_incident_type_version_idx")
  @@map("compliance_report_snapshots")
}

// C12 — Redaction draft (maker side of maker-checker). Editable ONLY in `draft`;
// SUBMITTED is read-only; APPROVED/REJECTED/CANCELLED/SUPERSEDED are terminal.
// Controlled status transitions are validated server-side and mirrored append-only
// into compliance_approval_history_events. No source field values are stored here.
model ComplianceRedactionDraft {
  id                  String    @id @default(cuid())
  tenantId            String
  incidentId          String
  sourceReportId      String
  status              String    @default("draft") // RedactionDraftStatus
  revision            Int       @default(1)
  createdByUserId     String
  submittedByUserId   String?
  submittedAt         DateTime?
  approvedByUserId    String?
  approvedAt          DateTime?
  rejectedByUserId    String?
  rejectedAt          DateTime?
  rejectionReasonCode String?
  producedReportId    String?
  idempotencyKey      String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  tenant Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rules  ComplianceRedactionRule[]

  @@unique([id, tenantId])
  @@unique([tenantId, createdByUserId, sourceReportId, idempotencyKey], map: "crd_tenant_user_source_idem_key")
  @@index([tenantId, incidentId, status])
  @@map("compliance_redaction_drafts")
}

// C12 — a single field-path redaction rule (registry-validated). Editable only while
// the parent draft is `draft`. The confidential OTHER note is stored here but never
// enters the snapshot, timeline, audit, or manifest.
model ComplianceRedactionRule {
  id                   String   @id @default(cuid())
  tenantId             String
  draftId              String
  fieldPath            String
  action               String // RedactionAction
  reasonCode           String // RedactionReasonCode
  reasonNote           String? // CONFIDENTIAL (OTHER only) — never logged/exported
  replacementMarkerKey String?
  order                Int      @default(0)
  createdByUserId      String
  createdAt            DateTime @default(now())

  tenant Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  draft  ComplianceRedactionDraft @relation(fields: [draftId, tenantId], references: [id, tenantId], onDelete: Cascade)

  @@unique([id, tenantId])
  @@index([tenantId, draftId, order])
  @@map("compliance_redaction_rules")
}

// C12 — export authorization request (dual control). The requester can never approve
// their own request. `recipientLabel` is a sanitized internal description only —
// never used to send anything.
model ComplianceExportAuthorization {
  id                  String    @id @default(cuid())
  tenantId            String
  incidentId          String
  reportId            String
  status              String    @default("requested") // ExportAuthorizationStatus
  purposeCode         String
  purposeNote         String? // CONFIDENTIAL (OTHER only) — never in the manifest/audit
  recipientType       String
  recipientLabel      String? // sanitized internal label; no contact data
  requestedByUserId   String
  requestedAt         DateTime  @default(now())
  approvedByUserId    String?
  approvedAt          DateTime?
  rejectedByUserId    String?
  rejectedAt          DateTime?
  rejectionReasonCode String?
  expiresAt           DateTime
  usedAt              DateTime?
  cancelledAt         DateTime?
  idempotencyKey      String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([id, tenantId])
  @@unique([tenantId, requestedByUserId, reportId, idempotencyKey], map: "cea_tenant_user_report_idem_key")
  @@index([tenantId, incidentId, status])
  @@map("compliance_export_authorizations")
}

// C12 — IMMUTABLE internal export package manifest. Describes WHAT a future export
// would contain — never a file, path, URL, or bytes. App role: SELECT + INSERT only
// (UPDATE/DELETE revoked in the migration).
model ComplianceExportPackageManifest {
  id                   String   @id @default(cuid())
  tenantId             String
  incidentId           String
  reportId             String
  authorizationId      String
  packageVersion       Int
  schemaVersion        String
  status               String   @default("prepared") // ExportPackageStatus
  purposeCode          String
  recipientType        String
  preparedByUserId     String
  preparedAt           DateTime @default(now())
  reportSnapshotHash   String
  redactionRuleSetHash String?
  authorizationHash    String
  manifestHash         String
  previousManifestHash String?
  manifestPayload      Json
  idempotencyKey       String?
  createdAt            DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([id, tenantId])
  @@unique([tenantId, incidentId, reportId, packageVersion], map: "cepm_tenant_incident_report_version_key")
  @@unique([tenantId, preparedByUserId, authorizationId, idempotencyKey], map: "cepm_tenant_user_auth_idem_key")
  @@index([tenantId, incidentId, packageVersion])
  @@map("compliance_export_package_manifests")
}

// C12 — APPEND-ONLY approval / workflow history. App role: SELECT + INSERT only.
// Records the decision trail; never source field values, notes, payloads, or PII.
model ComplianceApprovalHistoryEvent {
  id          String   @id @default(cuid())
  tenantId    String
  incidentId  String
  entityType  String // draft | export_authorization | manifest
  entityId    String
  eventType   String
  actorUserId String?
  metadata    Json? // sanitized ids/status/reasonCode only
  createdAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([id, tenantId])
  @@index([tenantId, entityType, entityId, createdAt])
  @@map("compliance_approval_history_events")
}

enum LeadStatus {
  new
  contacted
  closed
}

/// Public inbound lead / contact request (Book a demo, Contact form).
/// Global — not tied to a tenant. Contains no secrets.
model Lead {
  id        String     @id @default(cuid())
  name      String
  email     String
  company   String?
  website   String?
  platforms String[]
  message   String?
  source    String     @default("book_demo")
  consent   Boolean    @default(false)
  status    LeadStatus @default(new)
  // Internal, team-only notes. Never shown publicly.
  notes     String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([status, createdAt])
  @@map("leads")
}

// ===========================================================================================
// V1.45C1 — GLOBAL, PRIVACY-SAFE tenant-deletion receipt. Deliberately has NO tenant foreign key
// (it must SURVIVE the tenant cascade as durable proof that a deletion occurred). Reached ONLY via
// the systemDb tenant-deletion service — never tenant-facing web code.
//
// It stores AGGREGATE, NON-PII facts only. It MUST NOT contain: tenant name, user email/name,
// tokens, webhook payloads, content text, provider response bodies, internal notes, or raw
// exception messages. `deletedTenantId` and `requestedByUserId` are OPAQUE cuids (internal
// handles, not personal data). `providerResultSummary` is a safe count-by-classification object.
// `failureClass` is a NORMALIZED allowlisted classification, never a raw error string.
// ===========================================================================================
model TenantDeletionReceipt {
  id                    String               @id @default(cuid())
  // Server-generated, unique — the idempotency key for the whole lifecycle. Two concurrent
  // requests converge on one operationId; a retry re-uses it; a stale one affects nothing.
  operationId           String               @unique
  deletedTenantId       String
  requestedByUserId     String?
  // "tenant_owner" | "platform_admin" — the authority that initiated deletion (never a tenant name).
  initiatedAuthority    String
  status                TenantDeletionStatus @default(requested)
  requestedAt           DateTime             @default(now())
  completedAt           DateTime?
  providerAccountCount  Int                  @default(0)
  // Safe aggregate, e.g. { "revoked_provider": 0, "revoke_unsupported": 2, "clustersInvalidated": 1 }.
  providerResultSummary Json?
  webhookEventsPurged   Int                  @default(0)
  tenantRowDeleted      Boolean              @default(false)
  // Normalized failure classification (e.g. "provider_cleanup_failed", "cascade_failed"); never PII.
  failureClass          String?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  @@index([deletedTenantId])
  @@index([status])
  @@map("tenant_deletion_receipts")
}

// V1.45C2 — who initiated a user identity erasure. `self` = the authenticated user erasing their own
// global identity; `platform_admin` = a V1.45A Platform Admin via the separate `user:delete` capability.
enum UserDeletionInitiator {
  self
  platform_admin
}

// ===========================================================================================
// V1.45C2 — GLOBAL, PRIVACY-SAFE user-identity deletion receipt. Deliberately has NO User foreign key
// (it MUST survive the hard-delete of the user as durable proof that an erasure occurred — the app's
// privacy policy promises GDPR erasure). Reached ONLY via the systemDb user-erasure service. Written
// in the SAME transaction as the User delete, so a receipt exists iff the erasure committed.
//
// It stores AGGREGATE, NON-PII facts only. It MUST NOT contain: email, name, tenant names, membership
// role names, platformRole, session hashes, tokens, IP/user-agent, content, or raw exception messages.
// `deletedUserId` and `requestedByUserId` are OPAQUE copied cuids (internal handles, no FK, not PII).
// No status field: a receipt is created ONLY on a committed erasure (a blocked erase writes nothing).
// ===========================================================================================
model UserDeletionReceipt {
  id                String                @id @default(cuid())
  // Server-generated, unique — the idempotency key. A converged concurrent/repeat erase reuses the
  // existing receipt rather than creating a second.
  operationId       String                @unique
  deletedUserId     String
  initiatedBy       UserDeletionInitiator
  requestedByUserId String?
  membershipCount   Int                   @default(0)
  sessionCount      Int                   @default(0)
  requestedAt       DateTime              @default(now())
  completedAt       DateTime?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@index([deletedUserId])
  @@map("user_deletion_receipts")
}

// V1.45C3 — how a global lead erasure targeted rows: by exact lead id, or by an exact normalized email.
enum LeadErasureMode {
  lead_id
  normalized_email
}

// ===========================================================================================
// V1.45C3 — GLOBAL, PRIVACY-SAFE lead-erasure receipt. Reached ONLY via the systemDb, Platform-Admin-
// authorized (`leads:erase`) lead-erasure service. Written in the SAME transaction as the lead delete.
//
// It stores AGGREGATE, NON-PII facts only. It MUST NOT contain: the erased lead id list, email or any
// email HASH (an unsalted email hash is a long-lived re-identification oracle — deliberately omitted),
// name, company, website, message, notes, tenant data, or raw exception messages. `requestedByUserId`
// is an OPAQUE cuid with no User FK (it survives a later actor erasure). `mode` records only WHICH
// exact-match strategy ran — never the target value itself.
// ===========================================================================================
model LeadErasureReceipt {
  id                String          @id @default(cuid())
  // Server-generated, unique — never client-selectable.
  operationId       String          @unique
  requestedByUserId String?
  mode              LeadErasureMode
  matchedCount      Int             @default(0)
  requestedAt       DateTime        @default(now())
  completedAt       DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@map("lead_erasure_receipts")
}

// V1.70 (Release B / B2) — tenant-scoped product notifications. RLS-enforced (enable + FORCE + policy
// + grant to tamanor_app in the migration). userId = null means tenant-wide (every member sees it);
// a specific userId targets one member. dedupeKey (unique per tenant) prevents spam on recurring sync
// cycles — recurrence granularity is encoded by the caller into the key (e.g. a day bucket). metadata
// is safe JSON only (NEVER tokens / provider payloads).
enum NotificationType {
  first_sync_completed
  sync_failed
  risk_comment_detected
  monitoring_disabled_by_plan
  trial_ending
  trial_expired
  payment_failed
  account_reconnect_required
}

enum NotificationSeverity {
  info
  warning
  critical
}

model Notification {
  id          String               @id @default(cuid())
  tenantId    String
  userId      String?
  type        NotificationType
  severity    NotificationSeverity @default(info)
  titleKey    String
  messageKey  String
  metadata    Json                 @default("{}")
  dedupeKey   String
  createdAt   DateTime             @default(now())
  readAt      DateTime?
  emailSentAt DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, dedupeKey])
  @@index([tenantId, userId, readAt, createdAt])
  @@index([tenantId, createdAt])
  @@map("notifications")
}

// V1.71 (Release B / B4) — tenant-scoped team invites. RLS-enforced (enable + FORCE + policy + grant in
// the migration). The token is stored ONLY as a sha256 hash (plaintext lives solely in the emailed link).
// A partial unique index (migration) forbids two PENDING invites for the same (tenant, email). Expired /
// revoked invites free their reserved seat. Accept is transactional + single-use + idempotent.
enum InviteStatus {
  pending
  accepted
  revoked
  expired
}

model Invite {
  id              String       @id @default(cuid())
  tenantId        String
  emailNormalized String
  role            Role         @default(viewer)
  tokenHash       String       @unique
  status          InviteStatus @default(pending)
  invitedByUserId String?
  expiresAt       DateTime
  acceptedAt      DateTime?
  revokedAt       DateTime?
  lastSentAt      DateTime     @default(now())
  createdAt       DateTime     @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([tenantId, emailNormalized])
  @@map("invites")
}

// ===========================================================================================
// CS-C1 — Child Safety Family Domain Foundation. FAMILY-workspace-only, tenant-scoped tables.
// A ProtectedProfile is NOT a User: it carries NO login/email/phone/Meta id/external account
// id/username/message/media/precise location — only a guardian-chosen label, an age band, and a
// protection status. Enums are stored as strings validated against the CS-C0 @guardora/core
// domain enums (never duplicated as DB enum types), so CS-C2 workflows are not over-constrained.
// Access is gated by BOTH tenant RLS AND workspace kind + FamilyRole (see child-safety-family.ts).
// CHECK constraints, the partial "one active" unique index, RLS and GRANTs live in the hand-
// authored migration 20260802090000_cs_c1_family_domain.
// ===========================================================================================

model ProtectedProfile {
  id               String    @id @default(cuid())
  tenantId         String
  // Guardian-CHOSEN label only (e.g. "Younger child"). NEVER the child's real name/contact/identity.
  guardianLabel    String?
  ageBand          String // AgeBand (under_10 | age_10_12 | age_13_15 | age_16_17)
  protectionStatus String    @default("inactive") // ProtectionStatus (inactive|monitoring|active|paused)
  // CS-C7 — preferred Family UI language (bounded: en|sk|de). A display preference only — content-free,
  // NEVER the child's real name/DOB/identity.
  language         String? // PROFILE_LANGUAGES (en|sk|de) or null
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  // Archiving is soft: the row and its guardian relationships remain historically referencable.
  archivedAt       DateTime?

  tenant                          Tenant                                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  guardianRelationships           GuardianRelationship[]
  consentRecords                  ConsentRecord[] // CS-C2
  safetySignals                   SafetySignal[] // CS-C3
  recipientAuthorizationDecisions SafetyRecipientAuthorizationDecision[] // CS-C4
  safetySignalDeliveries          SafetySignalDelivery[] // CS-C5
  familyGuardianInvitations       FamilyGuardianInvitation[] // CS-C8

  @@unique([id, tenantId])
  @@index([tenantId, archivedAt])
  @@map("protected_profiles")
}

model GuardianRelationship {
  id                       String    @id @default(cuid())
  tenantId                 String
  guardianMembershipId     String
  protectedProfileId       String
  relationshipType         String // GuardianRelationshipType (parent|legal_guardian|trusted_adult|safety_professional)
  authorityLevel           String // GuardianAuthorityLevel (full|limited|read_only)
  // CS-C7 — the guardian's ROLE within the profile's circle (GuardianRole: primary|secondary|emergency|
  // view_only). Separate axis from relationshipType/authorityLevel; a role change never alters those.
  // App-required (no DB default). At most one ACTIVE primary per profile — enforced by the partial unique
  // index `gr_one_active_primary_per_profile` (SQL-only; Prisma cannot express a WHERE-partial unique).
  guardianRole             String
  // Status, consent and safe-recipient eligibility are DELIBERATELY SEPARATE axes. A guardian
  // relationship NEVER implies consent or safe-recipient eligibility (defaults below). No automatic
  // status transitions in CS-C1 — everything is an explicit, audited action.
  status                   String    @default("pending") // GuardianRelationshipStatus (pending|verified|suspended|revoked)
  consentStatus            String    @default("not_requested") // ConsentStatus
  consentType              String? // ConsentType (where applicable)
  safeRecipientEligibility String    @default("not_verified") // SafetyRecipientEligibility (never auto-eligible)
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
  revokedAt                DateTime?
  archivedAt               DateTime?

  tenant                   Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // Same-tenant composite FKs — cross-tenant linking is impossible at the DB level.
  guardianMembership       Membership                @relation(fields: [guardianMembershipId, tenantId], references: [id, tenantId], onDelete: Cascade)
  protectedProfile         ProtectedProfile          @relation(fields: [protectedProfileId, tenantId], references: [id, tenantId], onDelete: Cascade)
  // CS-C2 back-relations.
  authorityRecords         GuardianAuthorityRecord[]
  safeRecipientAssessments SafeRecipientAssessment[]

  @@unique([id, tenantId])
  @@index([tenantId, protectedProfileId])
  @@index([tenantId, guardianMembershipId])
  @@map("guardian_relationships")
}

// ===========================================================================================
// CS-C8 — Family Guardian Invitation. A SEPARATE, FAMILY-only, tenant-scoped, content-free entity —
// NOT the Business `invites` table, NOT `notifications`, NOT any CS-C1..C7 record. The invitation grants
// NOTHING by itself; accepting it may only create/reuse a Membership + create/reactivate a
// GuardianRelationship in one transaction. Only the token's sha256 hash is stored. No PII of a minor.
// Bounded status/role CHECKs + the one-pending-per(profile,email) partial unique index live in the
// hand-authored migration (Prisma cannot express WHERE-partial uniques or CHECKs).
// ===========================================================================================
model FamilyGuardianInvitation {
  id                       String    @id @default(cuid())
  tenantId                 String
  protectedProfileId       String
  // ADULT invitee email (normalized) — never a child's identity; never logged/audited in the clear.
  invitedEmailNormalized   String
  invitedByMembershipId    String
  intendedFamilyRole       String // FamilyRole (invitable subset: guardian|trusted_adult|safety_professional|family_viewer)
  intendedGuardianRole     String // GuardianRole (primary|secondary|emergency|view_only)
  intendedRelationshipType String // GuardianRelationshipType (parent|legal_guardian|trusted_adult|safety_professional)
  status                   String    @default("pending") // pending|accepted|declined|revoked|expired
  tokenHash                String    @unique // sha256 of the opaque token; the plaintext is never stored
  expiresAt                DateTime
  acceptedAt               DateTime?
  declinedAt               DateTime?
  revokedAt                DateTime?
  acceptedByUserId         String?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  tenant           Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // Same-tenant composite FKs — cross-tenant linking is impossible at the DB level.
  protectedProfile ProtectedProfile @relation(fields: [protectedProfileId, tenantId], references: [id, tenantId], onDelete: Cascade)
  invitedBy        Membership       @relation(fields: [invitedByMembershipId, tenantId], references: [id, tenantId], onDelete: Cascade)
  acceptedByUser   User?            @relation(fields: [acceptedByUserId], references: [id], onDelete: SetNull)

  @@unique([id, tenantId])
  @@index([tenantId, status])
  @@index([tenantId, protectedProfileId])
  @@index([tenantId, invitedEmailNormalized, status])
  @@index([expiresAt])
  @@map("family_guardian_invitations")
}

// ===========================================================================================
// CS-C2 — Consent, Guardian Authority & Safe Recipients. FAMILY-only, tenant-scoped. Four axes
// (relationship / authority / consent / eligibility) are DELIBERATELY SEPARATE records that are
// never auto-derived from one another. Domain values are TEXT validated against @guardora/core
// enums (no DB enum types → CS-C3 not locked in). No document/evidence storage; verificationMethod
// and reasonCode are allow-listed process metadata only. History is preserved (revoke/expire/
// archive; app role has no DELETE). CHECK constraints, partial "one active" unique indexes, RLS and
// GRANTs live in the hand-authored migration 20260803090000_cs_c2_consent_authority_safe_recipients.
// Required links (authority→relationship, consent→profile, assessment→relationship) are same-tenant
// composite FKs. Optional links (consent.guardianRelationshipId, grantedByMembershipId,
// assessedByMembershipId) carry the shared tenantId and are enforced same-tenant in the REPOSITORY
// (RLS-scoped lookup, fail-closed) with NO DB FK — history survives a member removal, and this avoids
// SET NULL on the NOT NULL shared tenantId. Prisma also cannot model an optional composite relation
// that shares a required scalar, so those optional links are scalar-only here.
// ===========================================================================================

model GuardianAuthorityRecord {
  id                     String    @id @default(cuid())
  tenantId               String
  guardianRelationshipId String
  authorityType          String // GuardianAuthorityType
  // CS-C9 — the granted SCOPE (GuardianAuthorityLevel: full|limited|read_only). Separate axis from
  // authorityType/GuardianRole/relationshipType/FamilyRole; never auto-derived. Bounded CHECK in the
  // hand-authored CS-C9 migration. App-required (backfilled to read_only for pre-C9 rows).
  authorityLevel         String    @default("read_only")
  authorityStatus        String    @default("pending") // GuardianAuthorityStatus (pending|verified|suspended|revoked|expired|rejected)
  validFrom              DateTime  @default(now())
  validUntil             DateTime? // validUntil < now ⇒ inactive even if status stayed VERIFIED
  verifiedAt             DateTime?
  verificationMethod     String? // VerificationMethod — process metadata only, NEVER proof/document
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  revokedAt              DateTime?
  archivedAt             DateTime?

  tenant               Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  guardianRelationship GuardianRelationship @relation(fields: [guardianRelationshipId, tenantId], references: [id, tenantId], onDelete: Cascade)

  @@unique([id, tenantId])
  @@index([tenantId, guardianRelationshipId, authorityStatus])
  @@map("guardian_authority_records")
}

model ConsentRecord {
  id                     String    @id @default(cuid())
  tenantId               String
  protectedProfileId     String
  guardianRelationshipId String? // optional link — same-tenant enforced in repository (no DB FK; history survives member removal)
  consentType            String // ConsentType
  consentStatus          String    @default("not_requested") // ConsentStatus (active == GRANTED, withdrawn == REVOKED)
  grantedByMembershipId  String? // required for GRANTED — same-tenant enforced in repository (no DB FK)
  grantedAt              DateTime?
  validFrom              DateTime?
  validUntil             DateTime?
  revokedAt              DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  archivedAt             DateTime?

  tenant           Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  protectedProfile ProtectedProfile @relation(fields: [protectedProfileId, tenantId], references: [id, tenantId], onDelete: Cascade)

  @@unique([id, tenantId])
  @@index([tenantId, protectedProfileId, consentStatus])
  @@index([tenantId, guardianRelationshipId])
  @@map("consent_records")
}

model SafeRecipientAssessment {
  id                     String    @id @default(cuid())
  tenantId               String
  guardianRelationshipId String
  eligibilityStatus      String    @default("not_verified") // SafetyRecipientEligibility (never auto-eligible)
  assessmentStatus       String    @default("not_started") // SafeRecipientAssessmentStatus
  assessedByMembershipId String? // required for APPROVED — same-tenant enforced in repository (no DB FK)
  assessedAt             DateTime?
  reasonCode             String? // SafeRecipientReasonCode (allow-listed enum, NEVER free text)
  validUntil             DateTime?
  revokedAt              DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  archivedAt             DateTime?

  tenant               Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  guardianRelationship GuardianRelationship @relation(fields: [guardianRelationshipId, tenantId], references: [id, tenantId], onDelete: Cascade)

  @@unique([id, tenantId])
  @@index([tenantId, guardianRelationshipId, assessmentStatus])
  @@map("safe_recipient_assessments")
}

// ===========================================================================================
// CS-C3 — Safety Signal Foundation. FAMILY-only, tenant-scoped. A SafetySignal is ONLY a bounded,
// structured record that some external/future-local system reported a TYPE of possible safety risk
// for a ProtectedProfile — NOT a message/incident/evidence/alert/AI-classification/guilt-decision/
// action. It holds occurrence + classification METADATA + review state only (CS-C3 = points 1–3);
// there is NO delivery/alert/notification/recipient/incident/case/escalation. `signalType` reuses the
// CS-0 RiskType category; `severity` reuses CS-0 SafetySeverity; all values are TEXT validated in
// @guardora/core (no DB enum types → CS-C4 not locked in). `sourceReference`/`occurrenceBucket` are
// OPAQUE, length-bounded, char-allowlisted (never a URL/username/message-id/raw-content hash). No raw
// content, free text, or arbitrary JSON is ever stored. `reviewedByMembershipId` is optional and
// enforced same-tenant in the repository (no DB FK; history survives a member removal). The profile
// link is a same-tenant composite FK with ON DELETE NO ACTION so signal history is never cascade-
// deleted by a profile delete (only tenant lifecycle may remove it, via the tenant FK). CHECK
// constraints, RLS and GRANTs live in the hand-authored migration 20260804090000_cs_c3_safety_signal.
// ===========================================================================================

model SafetySignal {
  id                     String    @id @default(cuid())
  tenantId               String
  protectedProfileId     String
  signalType             String // RiskType (CS-0): GROOMING|SEXUAL_SOLICITATION|SEXTORTION|MEETING_ATTEMPT|CYBERBULLYING|THREAT|IDENTITY_MANIPULATION
  severity               String // SafetySeverity (CS-0): low|medium|high|critical
  confidenceBand         String    @default("unknown") // SafetyConfidenceBand — a coarse band, NEVER a raw model score
  sourceType             String // SafetySignalSourceType (no real connector in CS-C3)
  sourceReference        String? // OPAQUE, ≤64, [A-Za-z0-9_-] — never a URL/username/message-id/raw content
  occurrenceBucket       String? // safe time bucket / opaque dedupe token, ≤32 — never a raw-content hash
  reviewStatus           String    @default("new") // SafetySignalReviewStatus
  detectedAt             DateTime?
  receivedAt             DateTime  @default(now())
  reviewedAt             DateTime?
  reviewedByMembershipId String? // required for final review states — same-tenant enforced in repository (no DB FK)
  resolutionCode         String? // SafetySignalResolutionCode (allow-listed; only on a final review state)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  archivedAt             DateTime?

  tenant                          Tenant                                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  protectedProfile                ProtectedProfile                       @relation(fields: [protectedProfileId, tenantId], references: [id, tenantId], onDelete: NoAction)
  // CS-C4 back-relation.
  recipientAuthorizationDecisions SafetyRecipientAuthorizationDecision[]
  safetySignalDeliveries          SafetySignalDelivery[] // CS-C5

  // CS-C4 — composite unique so a recipient authorization decision can reference (id, tenantId).
  @@unique([id, tenantId])
  @@index([tenantId, protectedProfileId, receivedAt])
  @@index([tenantId, reviewStatus, receivedAt])
  @@index([tenantId, signalType])
  @@map("safety_signals")
}

// ===========================================================================================
// CS-C4 — Authorized Recipient Resolution & Disclosure Decisions. FAMILY-only, tenant-scoped. For a
// specific SafetySignal, records WHETHER a membership is (at evaluation time) an authorized recipient
// of a specific disclosure SCOPE — point 6 of the pipeline ONLY. It NEVER delivers anything and never
// mutates any CS-1/C2/C3 record. Each row is a HISTORICAL snapshot of the record IDs + safe enum values
// used at evaluation; effectiveness is recomputed by a pure fn + a live CS-2 chain re-check (a decision
// stops being effective if its underlying consent/authority/relationship/assessment is later revoked or
// the signal is archived). `disclosureScope` is a bounded, deterministic, comma-joined allow-listed
// scalar (NEVER JSON/free text). Required links (signal, profile) are same-tenant composite FKs with
// ON DELETE NO ACTION; optional links (relationship, authority, consent, assessment) are same-tenant
// composite FKs in the migration (Prisma cannot model an optional composite sharing tenantId).
// `recipientMembershipId` has NO DB FK: `removeMember` (team-repo.ts) hard-deletes memberships, so a
// NO ACTION/RESTRICT FK would block legitimate member removal and CASCADE would delete authorization
// history — so same-tenant is enforced in the repository (RLS lookup). CHECK constraints, RLS and
// GRANTs live in the hand-authored migration 20260805090000_cs_c4_recipient_authorization.
// ===========================================================================================

model SafetyRecipientAuthorizationDecision {
  id                        String    @id @default(cuid())
  tenantId                  String
  safetySignalId            String
  protectedProfileId        String
  recipientMembershipId     String // same-tenant enforced in repository (no DB FK — member removal lifecycle)
  guardianRelationshipId    String? // snapshot ref — same-tenant composite FK in migration
  guardianAuthorityRecordId String? // snapshot ref — same-tenant composite FK in migration
  consentRecordId           String? // snapshot ref — same-tenant composite FK in migration
  safeRecipientAssessmentId String? // snapshot ref — same-tenant composite FK in migration
  decisionStatus            String // RecipientAuthorizationDecisionStatus (pending|authorized|denied|revoked|expired|superseded)
  disclosureScope           String    @default("") // bounded comma-joined allow-listed SafetyDisclosureScope set (no JSON/free text)
  reasonCode                String // RecipientAuthorizationReasonCode (allow-listed)
  evaluatedAt               DateTime  @default(now())
  validUntil                DateTime?
  revokedAt                 DateTime?
  supersededAt              DateTime?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt
  archivedAt                DateTime?

  tenant           Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  safetySignal     SafetySignal           @relation(fields: [safetySignalId, tenantId], references: [id, tenantId], onDelete: NoAction)
  protectedProfile ProtectedProfile       @relation(fields: [protectedProfileId, tenantId], references: [id, tenantId], onDelete: NoAction)
  deliveries       SafetySignalDelivery[] // CS-C5

  // CS-C5 — composite unique so an internal delivery can reference (id, tenantId).
  @@unique([id, tenantId])
  @@index([tenantId, safetySignalId, decisionStatus], map: "sread_tenant_signal_status_idx")
  @@index([tenantId, protectedProfileId], map: "sread_tenant_profile_idx")
  @@index([tenantId, recipientMembershipId], map: "sread_tenant_recipient_idx")
  @@index([tenantId, safetySignalId, recipientMembershipId, createdAt], map: "sread_effective_lookup_idx")
  @@map("safety_recipient_authorization_decisions")
}

// ===========================================================================================
// CS-C5 — Internal Delivery Foundation. FAMILY-only, tenant-scoped. A SafetySignalDelivery is ONLY an
// INTERNAL record that a minimal, already-authorized safety disclosure is PREPARED for a specific
// authorized recipient — point 7 of the pipeline. It NEVER sends anything (no email/SMS/push/webhook/
// notification/incident/case/evidence, no platform contact, no raw content) and mutates no CS-1..C4
// record. A delivery may exist ONLY for a currently-EFFECTIVE CS-C4 recipient authorization decision
// (re-checked in the repository via getEffectiveRecipientAuthorization). `deliveryChannel` is
// internal-only (internal_inbox). The disclosure SNAPSHOT is safe enum + bounded scalars (scope,
// signalType, severity, occurrenceBucket?, recommendedActionClass?) — NEVER raw content/JSON/free text.
// Idempotency: unique (tenantId, recipientAuthorizationDecisionId, recipientMembershipId,
// idempotencyKey). Required links (signal, profile, decision) are same-tenant composite FKs with
// ON DELETE NO ACTION (never cascade-delete delivery history; tenant lifecycle cleans up via tenant FK).
// recipient/acknowledgedBy/declinedBy membership ids have NO DB FK: `removeMember` (team-repo.ts) hard-
// deletes memberships, so NO ACTION/RESTRICT would block member removal and CASCADE would delete
// history — same-tenant is enforced in the repository (RLS lookup). CHECK constraints, RLS and GRANTs
// live in the hand-authored migration 20260806090000_cs_c5_internal_delivery.
// ===========================================================================================

model SafetySignalDelivery {
  id                               String    @id @default(cuid())
  tenantId                         String
  safetySignalId                   String
  protectedProfileId               String
  recipientAuthorizationDecisionId String
  recipientMembershipId            String // same-tenant enforced in repository (no DB FK — member removal lifecycle)
  deliveryStatus                   String    @default("prepared") // SafetyDeliveryStatus
  deliveryChannel                  String    @default("internal_inbox") // SafetyDeliveryChannel — INTERNAL only
  disclosureScope                  String // snapshot of the CS-C4 authorized scope (comma-joined allow-listed, non-empty)
  signalType                       String // RiskType snapshot (CS-0)
  severity                         String // SafetySeverity snapshot (CS-0)
  occurrenceBucket                 String? // safe bucket snapshot (opaque; no raw-content hash)
  recommendedActionClass           String? // SafetyRecommendedActionClass (allow-listed; no free text)
  idempotencyKey                   String // bounded [A-Za-z0-9_-]; NOT derived from raw content
  preparedAt                       DateTime  @default(now())
  availableAt                      DateTime?
  acknowledgedAt                   DateTime?
  acknowledgedByMembershipId       String? // same-tenant enforced in repository (no DB FK)
  declinedAt                       DateTime?
  declinedByMembershipId           String? // same-tenant enforced in repository (no DB FK)
  failedAt                         DateTime?
  failureReasonCode                String? // SafetyDeliveryReasonCode (allow-listed)
  revokedAt                        DateTime?
  expiredAt                        DateTime?
  supersededAt                     DateTime?
  createdAt                        DateTime  @default(now())
  updatedAt                        DateTime  @updatedAt
  archivedAt                       DateTime?

  tenant                         Tenant                               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  safetySignal                   SafetySignal                         @relation(fields: [safetySignalId, tenantId], references: [id, tenantId], onDelete: NoAction)
  protectedProfile               ProtectedProfile                     @relation(fields: [protectedProfileId, tenantId], references: [id, tenantId], onDelete: NoAction)
  recipientAuthorizationDecision SafetyRecipientAuthorizationDecision @relation(fields: [recipientAuthorizationDecisionId, tenantId], references: [id, tenantId], onDelete: NoAction)

  @@unique([tenantId, recipientAuthorizationDecisionId, recipientMembershipId, idempotencyKey], map: "ssd_idempotency_key")
  @@index([tenantId, safetySignalId, deliveryStatus], map: "ssd_tenant_signal_status_idx")
  @@index([tenantId, protectedProfileId], map: "ssd_tenant_profile_idx")
  @@index([tenantId, recipientAuthorizationDecisionId], map: "ssd_tenant_decision_idx")
  @@index([tenantId, recipientMembershipId], map: "ssd_tenant_recipient_idx")
  @@index([tenantId, safetySignalId, recipientMembershipId, createdAt], map: "ssd_effective_lookup_idx")
  @@map("safety_signal_deliveries")
}

// ===========================================================================================
// CS-C6 — Workspace onboarding state (FAMILY + BUSINESS). One row per tenant. Tenant-scoped, RLS
// ENABLE+FORCE. Content-free: only the immutable workspaceKind, the current onboarding step (a safe
// enum), and lifecycle timestamps — never a name/label/PII. App role SELECT/INSERT/UPDATE only.
// CHECK + RLS + GRANTs in the hand-authored migration 20260807090000_cs_c6_workspace_onboarding.
// ===========================================================================================

model WorkspaceOnboardingState {
  id            String    @id @default(cuid())
  tenantId      String    @unique
  workspaceKind String // WorkspaceKind (immutable copy for convenience; source of truth is Tenant.workspaceKind)
  currentStep   String    @default("welcome") // WorkspaceOnboardingStep
  completedAt   DateTime?
  skippedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, currentStep])
  @@map("workspace_onboarding_states")
}
