# =============================================================================
# Guardora.ai — environment example
# Copy to .env and fill in. NEVER commit real secrets.
# No client passwords are ever stored. Only official OAuth tokens.
# =============================================================================

# --- Core ---
NODE_ENV=development
APP_URL=http://localhost:3000

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://guardora:guardora@localhost:5432/guardora?schema=public

# --- Auth / session ---
AUTH_SECRET=change-me-in-production

# --- AI Risk Engine ---
# Provider-agnostic. Placeholder classifier runs without a key.
AI_PROVIDER=placeholder
AI_API_KEY=
AI_MODEL=

# --- Worker ---
WORKER_SYNC_INTERVAL_MS=60000
WORKER_CONCURRENCY=4

# =============================================================================
# Platform connectors — official OAuth / API credentials ONLY.
# Leave blank until an app is registered with each platform.
# Placeholder connectors run without these.
# =============================================================================

# --- Meta (Facebook Page + Instagram Business) ---
# Official OAuth only. Full walkthrough: docs/META_SETUP.md
# Leave blank → dashboard shows "configuration missing" (no fake connection).
# App id/secret from developers.facebook.com → your app → Settings → Basic.
META_APP_ID=
META_APP_SECRET=
# Must EXACTLY match a "Valid OAuth Redirect URI" in Facebook Login settings.
META_REDIRECT_URI=http://localhost:3000/api/connectors/meta/callback
# Any random string; set the SAME value in Meta App → Webhooks → Verify token.
META_WEBHOOK_VERIFY_TOKEN=
# Feature flag: when true, the Meta connector makes LIVE read-only Graph API
# calls during sync. Default false → sync uses a clearly-labelled MOCK fallback.
# Set true only after connecting a real Page and passing Meta App Review.
META_LIVE_SYNC=false
# Feature flag: webhook-driven targeted read-only sync (V1.4 stub). Default false.
# When true, stored webhook events trigger a read-only sync for the matching
# account. NEVER performs moderation actions.
META_WEBHOOK_SYNC=false
# OAuth scopes to request (comma-separated). Unset → safe minimal DEV smoke test:
#   public_profile,email
# Page read-only test (after adding these permissions to your Meta app):
#   public_profile,email,pages_show_list,pages_read_engagement
# Instagram/business scopes (instagram_basic, instagram_manage_comments,
# business_management) only after permissions/App Review per current Meta docs.
META_OAUTH_SCOPES=

# --- YouTube (Google / YouTube Data API) ---
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_OAUTH_REDIRECT_URI=http://localhost:3000/api/connectors/youtube/callback

# --- LinkedIn (Company Page) ---
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_OAUTH_REDIRECT_URI=http://localhost:3000/api/connectors/linkedin/callback

# --- TikTok (Business API) ---
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_OAUTH_REDIRECT_URI=http://localhost:3000/api/connectors/tiktok/callback

# --- Google Business Profile ---
GOOGLE_BUSINESS_CLIENT_ID=
GOOGLE_BUSINESS_CLIENT_SECRET=
GOOGLE_BUSINESS_OAUTH_REDIRECT_URI=http://localhost:3000/api/connectors/google-business/callback

# --- Token storage (production) ---
# plaintext (dev only) | aes-gcm | kms. Production REJECTS plaintext.
TOKEN_ENCRYPTION_MODE=plaintext
# Required when TOKEN_ENCRYPTION_MODE=aes-gcm. Base64-encoded 32 bytes (AES-256).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TOKEN_ENCRYPTION_KEY=

# --- Automatic read-only sync (worker) ---
# When true, the worker periodically runs a read-only sync for eligible
# connected accounts. Reads only — never executes a platform action. Default off.
AUTO_SYNC_ENABLED=false
AUTO_SYNC_INTERVAL_SECONDS=300

# --- Comment translation (multilingual intelligence) ---
# When enabled with a real provider, non-workspace-locale comments can be
# translated. Default off — no translation is ever fabricated; original preserved.
TRANSLATION_ENABLED=false
TRANSLATION_PROVIDER=none

# --- Provider interfaces (V1.16) ---
# Translation target: workspace_locale (brand default) or en.
TRANSLATION_TARGET_MODE=workspace_locale
# External AI risk provider (gated hybrid pipeline). Default off = Risk Rules V1
# alone. `mock` is dev/test only (refused in production). No real provider wired.
AI_RISK_PROVIDER_ENABLED=false
AI_RISK_PROVIDER=none
AI_RISK_MIN_CONFIDENCE=0.7

# --- Controlled live actions (V1.21B) — Facebook comment hide ONLY ---
# ALL fail-closed. Live hide runs only when LIVE_ACTIONS_ENABLED=true AND
# FACEBOOK_HIDE_ENABLED=true AND LIVE_ACTIONS_DRY_RUN=false. Default: no live action.
# Reply/delete are never enabled here; Instagram is out of scope.
LIVE_ACTIONS_ENABLED=false
FACEBOOK_HIDE_ENABLED=false
LIVE_ACTIONS_DRY_RUN=true
# V1.25 — second lock for the FIRST real live hide. Even with the three flags above
# set for live, a real Graph hide additionally requires LIVE_HIDE_TEST_CONFIRM=YES.
# Without it, hides stay blocked (live_confirm_required). Prevents an accidental live test.
LIVE_HIDE_TEST_CONFIRM=NO
# V1.27 Production Safe Mode — real live operation under the full brand safety
# envelope (kill switches, per-brand limits, rollback, audit). Still fail-closed:
# per-brand liveModeEnabled/autonomousHideEnabled default off; customer voice is
# never live-hidden. GLOBAL_KILL_SWITCH=true immediately stops ALL live actions.
PRODUCTION_SAFE_MODE_ENABLED=false
GLOBAL_KILL_SWITCH=false

# --- Real test mode (V1.21C) ---
# real = only real connected accounts sync + only real data shown (demo hidden).
# demo = seeded demo dataset (default for dev).
GUARDORA_DATA_MODE=demo
