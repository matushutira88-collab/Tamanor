{
  "name": "guardora",
  "version": "0.1.0",
  "private": true,
  "description": "Guardora.ai — AI Reputation Firewall for modern brands",
  "license": "UNLICENSED",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter @guardora/web dev",
    "dev:worker": "pnpm --filter @guardora/worker dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "db:generate": "pnpm --filter @guardora/db generate",
    "db:migrate": "pnpm --filter @guardora/db migrate",
    "db:migrate:deploy": "pnpm --filter @guardora/db migrate:deploy",
    "db:seed": "pnpm --filter @guardora/db seed",
    "db:reconnect-check": "pnpm --filter @guardora/db reconnect-check",
    "i18n-check": "pnpm --filter @guardora/worker exec tsx ../web/scripts/i18n-check.ts",
    "risk:test": "pnpm --filter @guardora/worker exec tsx ../../packages/ai/scripts/classifier.test.ts",
    "intel:test": "pnpm --filter @guardora/worker exec tsx ../../packages/ai/scripts/language.test.ts",
    "providers:test": "pnpm --filter @guardora/worker exec tsx ../../packages/ai/scripts/providers.test.ts",
    "memory:test": "pnpm --filter @guardora/worker exec tsx ../../packages/ai/scripts/memory.test.ts",
    "memory:db-test": "pnpm --filter @guardora/db exec tsx scripts/brand-memory.test.ts",
    "autoprotect:test": "pnpm --filter @guardora/worker exec tsx ../../packages/ai/scripts/auto-protect.test.ts",
    "control:test": "pnpm --filter @guardora/worker exec tsx ../../packages/ai/scripts/control-center.test.ts",
    "autoprotect:db-test": "pnpm --filter @guardora/db exec tsx scripts/auto-protect.test.ts",
    "autoprotect:value-test": "pnpm --filter @guardora/db exec tsx scripts/autoprotect-value.test.ts",
    "realmeta:test": "pnpm --filter @guardora/worker exec tsx ../../packages/ai/scripts/real-meta-blockers.test.ts",
    "fbhide:test": "pnpm --filter @guardora/worker exec tsx ../../packages/sync/scripts/facebook-hide.test.ts",
    "live-ux:test": "pnpm --filter @guardora/worker exec tsx ../../packages/sync/scripts/live-ux.test.ts",
    "production-safe:test": "pnpm --filter @guardora/worker exec tsx ../../packages/sync/scripts/production-safe-live.test.ts",
    "autonomous-live:test": "pnpm --filter @guardora/worker exec tsx ../../packages/sync/scripts/autonomous-live.test.ts",
    "token-lifecycle:test": "pnpm --filter @guardora/worker exec tsx ../../packages/sync/scripts/token-lifecycle.test.ts",
    "token-connection:test": "pnpm --filter @guardora/worker exec tsx ../../packages/sync/scripts/token-connection.test.ts",
    "comment-lifecycle:test": "pnpm --filter @guardora/worker exec tsx ../../packages/sync/scripts/comment-lifecycle.test.ts",
    "facebook-diagnose:test": "pnpm --filter @guardora/worker exec tsx ../../packages/sync/scripts/facebook-diagnose.test.ts",
    "facebook-token:watchdog": "pnpm --filter @guardora/worker exec tsx ../../packages/sync/scripts/facebook-token-watchdog.ts",
    "facebook-token:diagnose": "pnpm --filter @guardora/worker exec tsx ../../packages/sync/scripts/facebook-token-diagnose.ts",
    "facebook-hide:diagnose": "pnpm --filter @guardora/worker exec tsx ../../packages/sync/scripts/facebook-hide-diagnose.ts",
    "real:cleanup-demo": "pnpm --filter @guardora/db exec tsx scripts/cleanup-demo.ts",
    "real:reset-content": "pnpm --filter @guardora/db exec tsx scripts/reset-content.ts",
    "demo:seed": "SEED_DEMO=true pnpm --filter @guardora/db seed",
    "realmode:test": "pnpm --filter @guardora/db exec tsx scripts/real-mode.test.ts",
    "reset:test": "pnpm --filter @guardora/db exec tsx scripts/reset-content.test.ts",
    "control:populate": "pnpm --filter @guardora/db exec tsx scripts/control-populate.ts",
    "controldb:test": "pnpm --filter @guardora/db exec tsx scripts/control-center.test.ts",
    "workflow:test": "pnpm --filter @guardora/db exec tsx scripts/workflow.test.ts",
    "risk:reclassify-demo": "pnpm --filter @guardora/db reclassify-demo",
    "db:studio": "pnpm --filter @guardora/db studio",
    "clean": "pnpm -r clean"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  }
}
