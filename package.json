{
  "name": "guardora",
  "version": "0.1.0",
  "private": true,
  "description": "Guardora.ai — AI Reputation Firewall for modern brands",
  "license": "UNLICENSED",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter @guardora/web dev",
    "dev:worker": "pnpm --filter @guardora/worker dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "db:generate": "pnpm --filter @guardora/db generate",
    "db:migrate": "pnpm --filter @guardora/db migrate",
    "db:migrate:deploy": "pnpm --filter @guardora/db migrate:deploy",
    "db:seed": "pnpm --filter @guardora/db seed",
    "db:reconnect-check": "pnpm --filter @guardora/db reconnect-check",
    "i18n-check": "pnpm --filter @guardora/worker exec tsx ../web/scripts/i18n-check.ts",
    "risk:test": "pnpm --filter @guardora/worker exec tsx ../../packages/ai/scripts/classifier.test.ts",
    "intel:test": "pnpm --filter @guardora/worker exec tsx ../../packages/ai/scripts/language.test.ts",
    "providers:test": "pnpm --filter @guardora/worker exec tsx ../../packages/ai/scripts/providers.test.ts",
    "memory:test": "pnpm --filter @guardora/worker exec tsx ../../packages/ai/scripts/memory.test.ts",
